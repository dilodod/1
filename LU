    loadBtn.Position = UDim2.new(0.36, 0, 0, 35)
    loadBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 255)
    loadBtn.Text = "LOAD"
    loadBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    loadBtn.TextSize = 10
    loadBtn.Font = Enum.Font.GothamBold
    loadBtn.Parent = frame
    
    local delBtn = Instance.new("TextButton")
    delBtn.Size = UDim2.new(0.28, 0, 0, 26)
    delBtn.Position = UDim2.new(0.67, 0, 0, 35)
    delBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    delBtn.Text = "DEL"
    delBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    delBtn.TextSize = 10
    delBtn.Font = Enum.Font.GothamBold
    delBtn.Parent = frame
    
    -- Status
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0.9, 0, 0, 20)
    status.Position = UDim2.new(0.05, 0, 0, 65)
    status.BackgroundTransparency = 1
    status.Text = ""
    status.TextColor3 = Color3.fromRGB(100, 150, 100)
    status.TextSize = 10
    status.Font = Enum.Font.Gotham
    status.Parent = frame
    
    saveBtn.MouseButton1Click:Connect(function()
        if self:SaveConfig(nameBox.Text) then
            status.Text = "✓ Сохранено"
        else
            status.Text = "✗ Ошибка"
            status.TextColor3 = Color3.fromRGB(200, 100, 100)
        end
        task.wait(2)
        status.Text = ""
        status.TextColor3 = Color3.fromRGB(100, 150, 100)
    end)
    
    loadBtn.MouseButton1Click:Connect(function()
        if self:LoadConfig(nameBox.Text) then
            status.Text = "✓ Загружено"
        else
            status.Text = "✗ Не найдено"
            status.TextColor3 = Color3.fromRGB(200, 100, 100)
        end
        task.wait(2)
        status.Text = ""
        status.TextColor3 = Color3.fromRGB(100, 150, 100)
    end)
    
    delBtn.MouseButton1Click:Connect(function()
        pcall(function() delfile("LightUILib_" .. nameBox.Text .. ".json") end)
        status.Text = "✓ Удалено"
        task.wait(2)
        status.Text = ""
    end)
    
    return frame
end

