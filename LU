local HighlightsFolder = Instance.new("Folder")
HighlightsFolder.Name = "ObjectHighlights"
HighlightsFolder.Parent = workspace

local activeHighlights = {}

local function clearHighlights()
	for _, highlight in ipairs(activeHighlights) do
		if highlight then
			highlight:Destroy()
		end
	end
	activeHighlights = {}
end

local function createHighlight(model, color)
	if not model or not model.Parent then return end
	
	-- Проверяем, нет ли уже подсветки
	for _, existing in ipairs(activeHighlights) do
		if existing.Adornee == model then
			return
		end
	end
	
	local highlight = Instance.new("Highlight")
	highlight.Name = "FinderHighlight"
	highlight.Adornee = model
	highlight.FillColor = color or SETTINGS.HighlightColor
	highlight.OutlineColor = SETTINGS.OutlineColor
	highlight.FillTransparency = SETTINGS.Transparency
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = HighlightsFolder
	
	table.insert(activeHighlights, highlight)
	return highlight
end

-- ═══════════════════════════════════════════════════════════
-- ПОИСК И ГРУППИРОВКА
-- ═══════════════════════════════════════════════════════════

local function findValidObjects()
	local validObjects = {}
	local checked = 0
	
	-- Сканируем workspace
	for _, obj in ipairs(workspace:GetDescendants()) do
		if checked >= SETTINGS.MaxObjects then break end
		
		-- Проверяем только Model и Parts
		if obj:IsA("Model") or obj:IsA("BasePart") then
			-- Пропускаем персонажей игроков
			if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
				continue
			end
			
			-- Пропускаем части персонажей
			if obj:IsA("BasePart") then
				local char = obj:FindFirstAncestorOfClass("Model")
				if char and char:FindFirstChildOfClass("Humanoid") then
					continue
				end
			end
			
			local target = obj
			if obj:IsA("BasePart") then
				-- Для частей берём родительскую модель если есть
				target = obj:FindFirstAncestorOfClass("Model") or obj
			end
			
			-- Проверяем критерии
			local matches, size, center = matchesCriteria(target)
			if matches then
				-- Проверяем, не добавили ли уже
				local alreadyAdded = false
				for _, existing in ipairs(validObjects) do
					if existing.Object == target then
						alreadyAdded = true
						break
					end
				end
				
				if not alreadyAdded then
					table.insert(validObjects, {
						Object = target,
						Size = size,
						Center = center
					})
				end
			end
			
			checked += 1
		end
	end
	
	return validObjects
end

local function groupNearbyObjects(objects)
	-- Группируем объекты по близости
	local groups = {}
	local assigned = {}
	
	for i, objData in ipairs(objects) do
		if assigned[i] then continue end
		
		local group = {objData}
		assigned[i] = true
		
		for j, otherData in ipairs(objects) do
			if i == j or assigned[j] then continue end
			
			local distance = (objData.Center - otherData.Center).Magnitude
			if distance <= SETTINGS.GroupRadius then
				table.insert(group, otherData)
				assigned[j] = true
			end
		end
		
		table.insert(groups, group)
	end
	
	return groups
end

-- ═══════════════════════════════════════════════════════════
-- ОСНОВНОЙ СКАНЕР
-- ═══════════════════════════════════════════════════════════

local function scanAndHighlight()
	clearHighlights()
	
	print("🔍 Сканирование объектов...")
	local validObjects = findValidObjects()
	print("✅ Найдено подходящих объектов: " .. #validObjects)
	
	if #validObjects == 0 then
		print("❌ Нет объектов, соответствующих критериям")
		return
	end
	
	local groups = groupNearbyObjects(validObjects)
	print("📦 Сформировано групп: " .. #groups)
	
	for _, group in ipairs(groups) do
		local isGroup = #group >= SETTINGS.MinGroupSize
		
		for _, objData in ipairs(group) do
			local color = isGroup and SETTINGS.GroupHighlightColor or SETTINGS.HighlightColor
			createHighlight(objData.Object, color)
			
			if isGroup then
				print(string.format("  📍 ГРУППА [%d объектов]: %s", #group, objData.Object:GetFullName()))
			else
				print(string.format("  📍 Одиночный: %s", objData.Object:GetFullName()))
			end
		end
	end
	
	print(string.format("🎨 Подсвечено объектов: %d", #activeHighlights))
end

