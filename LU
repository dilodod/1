local SETTINGS = {
	-- Главное: НЕ высокие (не земля)
	MaxHeight = 5,           -- Максимальная высота объекта (Y)
	MinHeight = 0.1,         -- Минимальная высота (чтобы не было слишком плоских)
	
	-- НЕ большие (по объёму/площади)
	MaxBaseSize = 30,        -- Максимальная площадь основания (X * Z)
	MaxVolume = 100,         -- Максимальный объём
	
	-- МОГУТ быть длинные (в любую сторону)
	MaxLengthRatio = 10,     -- Максимальное отношение длины к ширине/высоте
	
	-- Группировка рядом стоящих
	GroupRadius = 15,        -- Радиус для группировки объектов
	MinGroupSize = 2,        -- Минимум объектов для подсветки группы
	
	-- Визуал
	HighlightColor = Color3.fromRGB(0, 255, 255),    -- Цвет подсветки
	GroupHighlightColor = Color3.fromRGB(255, 165, 0), -- Цвет группы
	OutlineColor = Color3.fromRGB(255, 255, 255),
	Transparency = 0.5,
	
	-- Производительность
	ScanInterval = 2,        -- Секунды между сканированиями
	MaxObjects = 500,        -- Максимум объектов для проверки
}

-- ═══════════════════════════════════════════════════════════
-- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
-- ═══════════════════════════════════════════════════════════

local function getModelSize(model)
	-- Получаем размеры модели через BoundingBox
	local success, result = pcall(function()
		return model:GetBoundingBox()
	end)
	
	if success and result then
		local cf, size = result[1], result[2]
		return size
	end
	
	-- Fallback: считаем через детей
	local minPos = Vector3.new(math.huge, math.huge, math.huge)
	local maxPos = Vector3.new(-math.huge, -math.huge, -math.huge)
	local hasParts = false
	
	for _, child in ipairs(model:GetDescendants()) do
		if child:IsA("BasePart") then
			hasParts = true
			local pos = child.Position
			local halfSize = child.Size / 2
			
			minPos = Vector3.new(
				math.min(minPos.X, pos.X - halfSize.X),
				math.min(minPos.Y, pos.Y - halfSize.Y),
				math.min(minPos.Z, pos.Z - halfSize.Z)
			)
			maxPos = Vector3.new(
				math.max(maxPos.X, pos.X + halfSize.X),
				math.max(maxPos.Y, pos.Y + halfSize.Y),
				math.max(maxPos.Z, pos.Z + halfSize.Z)
			)
		end
	end
	
	if hasParts then
		return maxPos - minPos
	end
	
	return nil
end

local function getModelCenter(model)
	local success, result = pcall(function()
		return model:GetBoundingBox()
	end)
	
	if success and result then
		return result[1].Position
	end
	
	-- Fallback
	local totalPos = Vector3.zero
	local count = 0
	
	for _, child in ipairs(model:GetDescendants()) do
		if child:IsA("BasePart") then
			totalPos += child.Position
			count += 1
		end
	end
	
	if count > 0 then
		return totalPos / count
	end
	
	return nil
end

local function isGroundLike(size, position)
	-- Проверяем, похож ли объект на землю/пол
	if not size or not position then return true end
	
	local baseArea = size.X * size.Z
	local volume = baseArea * size.Y
	
	-- Земля обычно: очень широкая, очень низкая, огромная площадь
	if size.Y < 2 and baseArea > 100 then
		return true
	end
	
	-- Очень большой объём = скорее всего земля/террейн
	if volume > 1000 then
		return true
	end
	
	return false
end

local function matchesCriteria(model)
	-- Проверяем, подходит ли объект под критерии
	
	local size = getModelSize(model)
	local center = getModelCenter(model)
	
	if not size or not center then return false end
	
	-- 1. НЕ высокие (главное)
	if size.Y > SETTINGS.MaxHeight then
		return false
	end
	if size.Y < SETTINGS.MinHeight then
		return false
	end
	
	-- 2. НЕ похожи на землю
	if isGroundLike(size, center) then
		return false
	end
	
	-- 3. НЕ большие (по площади основания)
	local baseArea = size.X * size.Z
	if baseArea > SETTINGS.MaxBaseSize then
		return false
	end
	
	-- 4. НЕ большие по объёму
	local volume = baseArea * size.Y
	if volume > SETTINGS.MaxVolume then
		return false
	end
	
	-- 5. МОГУТ быть длинные (проверяем соотношение сторон)
	local maxDim = math.max(size.X, size.Y, size.Z)
	local minDim = math.min(size.X, size.Y, size.Z)
	
	if minDim > 0 then
		local ratio = maxDim / minDim
		if ratio > SETTINGS.MaxLengthRatio then
			-- Слишком вытянутый - пропускаем
			return false
		end
	end
	
	return true, size, center
end

