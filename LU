    b.TextSize = 9
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
    
    local listening = false
    local conn = nil
    
    b.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        b.Text = "..."
        b.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
        
        conn = UIS.InputBegan:Connect(function(i, g)
            if g then return end
            if i.UserInputType == Enum.UserInputType.Keyboard then
                if i.KeyCode ~= Enum.KeyCode.Escape and i.KeyCode ~= Enum.KeyCode.Insert then
                    Config.Keybinds[k] = i.KeyCode
                else
                    Config.Keybinds[k] = nil
                end
                listening = false
                b.BackgroundColor3 = Config.Keybinds[k] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(150, 150, 150)
                b.Text = Config.Keybinds[k] and Config.Keybinds[k].Name or "BIND"
                if conn then conn:Disconnect() conn = nil end
            end
        end)
    end)
    return b
end

local function updateToggleVisual(k, state)
    if toggleRefs[k] then
        TweenService:Create(toggleRefs[k].bg, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(150, 150, 150)}):Play()
        TweenService:Create(toggleRefs[k].knob, TweenInfo.new(0.2), {Position = state and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)}):Play()
    end
end

