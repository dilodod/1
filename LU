-- УПРАВЛЕНИЕ ВКЛАДКАМИ
function Window:CreateTab(name, layoutOrder)
    -- Удаляем существующую с таким же именем
    for i, existing in ipairs(self.Tabs) do
        if existing.Name == name then
            existing.Button:Destroy()
            existing.Content:Destroy()
            table.remove(self.Tabs, i)
            break
        end
    end
    
    local tab = {
        Name = name,
        Window = self,
        Items = {}
    }
    
    -- Кнопка вкладки
    tab.Button = Instance.new("TextButton")
    tab.Button.Name = "Tab_" .. name
    tab.Button.Size = UDim2.new(1, 0, 0, 36)
    tab.Button.BackgroundColor3 = self.Theme.TabInactive
    tab.Button.Text = "  " .. name
    tab.Button.TextColor3 = self.Theme.TextDim
    tab.Button.TextSize = 13
    tab.Button.Font = Enum.Font.GothamBold
    tab.Button.TextXAlignment = Enum.TextXAlignment.Left
    tab.Button.LayoutOrder = layoutOrder or (#self.Tabs + 1) * 10
    tab.Button.Parent = self.Sidebar
    CreateCorner(tab.Button, 8)
    CreateStroke(tab.Button, self.Theme.Border, 1)
    
    -- Контент вкладки
    tab.Content = Instance.new("ScrollingFrame")
    tab.Content.Name = name .. "_Content"
    tab.Content.Size = UDim2.new(1, -10, 1, -10)
    tab.Content.Position = UDim2.new(0, 5, 0, 5)
    tab.Content.BackgroundTransparency = 1
    tab.Content.Visible = false
    tab.Content.ScrollBarThickness = 4
    tab.Content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tab.Content.Parent = self.Content
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 8)
    listLayout.Parent = tab.Content
    
    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 5)
    padding.PaddingBottom = UDim.new(0, 10)
    padding.PaddingLeft = UDim.new(0, 5)
    padding.PaddingRight = UDim.new(0, 5)
    padding.Parent = tab.Content
    
    -- Переключение
    tab.Button.MouseButton1Click:Connect(function()
        self:SwitchTab(name)
    end)
    
    -- Hover
    tab.Button.MouseEnter:Connect(function()
        if self.CurrentTab ~= tab then
            TweenService:Create(tab.Button, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 245, 120)}):Play()
        end
    end)
    
    tab.Button.MouseLeave:Connect(function()
        if self.CurrentTab ~= tab then
            tab.Button.BackgroundColor3 = self.Theme.TabInactive
        end
    end)
    
    table.insert(self.Tabs, tab)
    
    -- Сортируем
    table.sort(self.Tabs, function(a, b) return a.Button.LayoutOrder < b.Button.LayoutOrder end)
    
    -- Обновляем инфо
    if self.InfoText then
        self.InfoText.Text = "Версия: " .. LightUILib.Version .. "\nВкладок: " .. #self.Tabs .. "\nАвтосохранение: ВКЛ"
    end
    
    print("[YellowUI] Создана вкладка:", name)
    return tab
end

function Window:RemoveTab(name)
    if name == "⚙️ Настройки" then
        self:ShowNotification("❌ Нельзя удалить настройки!")
        return false
    end
    
    for i, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            tab.Button:Destroy()
            tab.Content:Destroy()
            table.remove(self.Tabs, i)
            
            if self.CurrentTab == tab then
                self.CurrentTab = nil
                self:SwitchTab("⚙️ Настройки")
            end
            
            if self.InfoText then
                self.InfoText.Text = "Версия: " .. LightUILib.Version .. "\nВкладок: " .. #self.Tabs .. "\nАвтосохранение: ВКЛ"
            end
            
            self:ShowNotification("🗑️ Удалена: " .. name)
            return true
        end
    end
    return false
end

function Window:GetTab(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then return tab end
    end
    return nil
end

function Window:GetTabNames()
    local names = {}
    for _, tab in ipairs(self.Tabs) do
        table.insert(names, tab.Name)
    end
    return names
end

function Window:SwitchTab(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            tab.Content.Visible = true
            TweenService:Create(tab.Button, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.TabActive}):Play()
            tab.Button.TextColor3 = self.Theme.Text
            self.CurrentTab = tab
            
            if self.TabCallbacks[name] then
                self.TabCallbacks[name]()
            end
        else
            tab.Content.Visible = false
            tab.Button.BackgroundColor3 = self.Theme.TabInactive
            tab.Button.TextColor3 = self.Theme.TextDim
        end
    end
end

function Window:OnTabSelect(name, callback)
    self.TabCallbacks[name] = callback
end

