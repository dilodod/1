    scroll.Position = UDim2.new(0, 5, 0, 26)
    scroll.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.Parent = frame
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 2)
    listLayout.Parent = scroll
    
    local function updateList()
        for _, ch in pairs(scroll:GetChildren()) do
            if ch:IsA("TextButton") then ch:Destroy() end
        end
        
        if not self.Config then return end
        
        local allPlayers = {}
        for _, pl in pairs(Players:GetPlayers()) do
            if pl ~= LocalPlayer then
                table.insert(allPlayers, pl)
            end
        end
        
        table.sort(allPlayers, function(a, b) return a.Name:lower() < b.Name:lower() end)
        
        for _, pl in pairs(allPlayers) do
            local isWl = self.Config[whitelistKey] and self.Config[whitelistKey][pl.UserId]
            local isTg = self.Config[targetsKey] and self.Config[targetsKey][pl.UserId]
            
            local dist = math.huge
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") 
               and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
                dist = (pl.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            end
            
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -4, 0, 26)
            
            if isWl then
                btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            elseif isTg then
                btn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
            else
                btn.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
            end
            
            local status = ""
            if isWl then status = " [ИГНОР]" 
            elseif isTg then status = " [ЦЕЛЬ]" end
            
            btn.Text = pl.Name .. " [" .. math.floor(dist) .. "m]" .. status
            btn.TextColor3 = self.Theme.Text
            btn.TextSize = 10
            btn.Font = Enum.Font.Gotham
            btn.BorderSizePixel = 0
            btn.Parent = scroll
            
            btn.MouseButton1Click:Connect(function()
                if not isWl and not isTg then
                    if not self.Config[whitelistKey] then self.Config[whitelistKey] = {} end
                    self.Config[whitelistKey][pl.UserId] = true
                elseif isWl and not isTg then
                    self.Config[whitelistKey][pl.UserId] = nil
                    if not self.Config[targetsKey] then self.Config[targetsKey] = {} end
                    self.Config[targetsKey][pl.UserId] = true
                else
                    self.Config[whitelistKey][pl.UserId] = nil
                    self.Config[targetsKey][pl.UserId] = nil
                end
                updateList()
                self:AutoSave()
            end)
        end
        
        scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    end
    
    -- Auto-update
    task.spawn(function()
        while task.wait(0.5) do
            if self.CurrentTab and self.CurrentTab.Name == tab.Name then
                updateList()
            end
        end
    end)
    
    -- Clear button
    local clearBtn = Instance.new("TextButton")
    clearBtn.Size = UDim2.new(0.9, 0, 0, 22)
    clearBtn.Position = UDim2.new(0.05, 0, 1, -24)
    clearBtn.BackgroundColor3 = self.Theme.TabInactive
    clearBtn.Text = "Очистить все"
    clearBtn.TextColor3 = self.Theme.Text
    clearBtn.TextSize = 10
    clearBtn.Font = Enum.Font.GothamBold
    clearBtn.Parent = frame
    clearBtn.MouseButton1Click:Connect(function()
        if self.Config then
            self.Config[whitelistKey] = {}
            self.Config[targetsKey] = {}
            updateList()
            self:AutoSave()
        end
    end)
    
    return frame
end

-- === КОНФИГИ ===

function Window:SaveConfig(name)
    if not self.Config then return false end
    
    local data = {}
    for k, v in pairs(self.Config) do
        -- Пропускаем таблицы с UserId (Whitelist/Targets)
        if type(v) == "table" and (k:find("Whitelist") or k:find("Targets") or k:find("targets") or k:find("whitelist")) then
            data[k] = {}
            for id, val in pairs(v) do
                table.insert(data[k], id)
            end
        else
            data[k] = v
        end
    end
    
    local json = HttpService:JSONEncode(data)
    local success = pcall(function()
        writefile("LightUILib_" .. name .. ".json", json)
    end)
    return success
end

function Window:LoadConfig(name)
    local success, result = pcall(function()
        return readfile("LightUILib_" .. name .. ".json")
    end)
    
    if success and result and self.Config then
        local data = HttpService:JSONDecode(result)
        for k, v in pairs(data) do
            -- Восстанавливаем таблицы с UserId
            if type(v) == "table" and (k:find("Whitelist") or k:find("Targets") or k:find("targets") or k:find("whitelist")) then
                self.Config[k] = {}
                for _, id in ipairs(v) do
                    self.Config[k][id] = true
                end
            else
                self.Config[k] = v
            end
        end
        
        -- Обновляем UI
        for key, refs in pairs(self.ToggleRefs) do
            if self.Config[key] ~= nil then
                local state = self.Config[key]
                refs.bg.BackgroundColor3 = state and self.Theme.ToggleOn or self.Theme.ToggleOff
                refs.knob.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
            end
        end
        
        return true
    end
    return false
end

function Window:AutoSave()
    -- Авто-сохранение при изменениях (опционально)
    -- Можно вызвать явно через SaveConfig
end

