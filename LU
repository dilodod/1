    tabListFrame.Size = UDim2.new(0.9, 0, 0, 70)
    tabListFrame.Position = UDim2.new(0.05, 0, 0, 45)
    tabListFrame.BackgroundTransparency = 1
    tabListFrame.ScrollBarThickness = 4
    tabListFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabListFrame.Parent = frame
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 4)
    listLayout.Parent = tabListFrame
    
    local function updateTabList()
        for _, child in ipairs(tabListFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        
        for _, tab in ipairs(self.Tabs) do
            if tab.Name == "⚙️ Настройки" then continue end -- не показываем настройки
            
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 24)
            btn.BackgroundColor3 = self.Theme.TabInactive
            btn.Text = tab.Name .. " ❌"
            btn.TextColor3 = self.Theme.Text
            btn.TextSize = 11
            btn.Font = Enum.Font.Gotham
            btn.Parent = tabListFrame
            CreateCorner(btn, 4)
            
            btn.MouseButton1Click:Connect(function()
                self:RemoveTab(tab.Name)
                updateTabList()
            end)
        end
    end
    
    createBtn.MouseButton1Click:Connect(function()
        local name = newTabBox.Text:gsub("^%s*", ""):gsub("%s*$", "")
        if name ~= "" and name ~= "⚙️ Настройки" then
            self:CreateTab(name)
            newTabBox.Text = ""
            updateTabList()
            self:ShowNotification("✅ Вкладка создана: " .. name)
        end
    end)
    
    updateTabList()
    self._updateTabList = updateTabList
end

-- === УЛУЧШЕННОЕ УПРАВЛЕНИЕ ВКЛАДКАМИ ===

function Window:CreateTab(name, layoutOrder)
    -- Проверяем существование - ЗАМЕНЯЕМ старую вкладку
    for i, existingTab in ipairs(self.Tabs) do
        if existingTab.Name == name then
            print("[YellowUI] Замена существующей вкладки:", name)
            -- Сохраняем контент старой вкладки если нужно
            existingTab.Button:Destroy()
            existingTab.Content:Destroy()
            table.remove(self.Tabs, i)
            break
        end
    end
    
    local tab = {}
    tab.Name = name
    tab.Window = self
    tab.Items = {}
    
    -- Кнопка вкладки
    local btn = Instance.new("TextButton")
    btn.Name = "Tab_" .. name
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = self.Theme.TabInactive
    btn.Text = "  " .. name
    btn.TextColor3 = self.Theme.TextDim
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.LayoutOrder = layoutOrder or #self.Tabs + 1
    btn.Parent = self.Sidebar
    CreateCorner(btn, 8)
    CreateStroke(btn, self.Theme.Border, 1)
    
    -- Контент вкладки
    local content = Instance.new("ScrollingFrame")
    content.Name = name
    content.Size = UDim2.new(1, -10, 1, -10)
    content.Position = UDim2.new(0, 5, 0, 5)
    content.BackgroundTransparency = 1
    content.Visible = false
    content.ScrollBarThickness = 4
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.Parent = self.Content
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 8)
    listLayout.Parent = content
    
    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 5)
    padding.PaddingBottom = UDim.new(0, 10)
    padding.PaddingLeft = UDim.new(0, 5)
    padding.PaddingRight = UDim.new(0, 5)
    padding.Parent = content
    
    tab.Button = btn
    tab.Content = content
    
    -- Переключение
    btn.MouseButton1Click:Connect(function()
        self:SwitchTab(name)
    end)
    
    -- Hover эффекты
    btn.MouseEnter:Connect(function()
        if self.CurrentTab ~= tab then
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 245, 120)}):Play()
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if self.CurrentTab ~= tab then
            btn.BackgroundColor3 = self.Theme.TabInactive
        end
    end)
    
    table.insert(self.Tabs, tab)
    
    -- Сортируем по LayoutOrder
    table.sort(self.Tabs, function(a, b) return a.Button.LayoutOrder < b.Button.LayoutOrder end)
    
    -- Авто-выбор если первая (не считая настроек)
    local nonSettingsTabs = 0
    for _, t in ipairs(self.Tabs) do
        if t.Name ~= "⚙️ Настройки" then nonSettingsTabs = nonSettingsTabs + 1 end
    end
    
    if nonSettingsTabs == 1 and name ~= "⚙️ Настройки" then
        self:SwitchTab(name)
    end
    
    -- Обновляем инфо
    if self.InfoText then
        self.InfoText.Text = "Версия: " .. LightUILib.Version .. "\nВкладок: " .. #self.Tabs .. "\nАвтосохранение: ON\n"
    end
    
    print("[YellowUI] Создана вкладка:", name)
    return tab
end

function Window:RemoveTab(name)
    if name == "⚙️ Настройки" then
        self:ShowNotification("❌ Нельзя удалить настройки!")
        return false
    end
    
    for i, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            tab.Button:Destroy()
            tab.Content:Destroy()
            table.remove(self.Tabs, i)
            
            if self.CurrentTab == tab then
                self.CurrentTab = nil
                -- Переключаемся на первую доступную
                for _, t in ipairs(self.Tabs) do
                    if t.Name ~= "⚙️ Настройки" then
                        self:SwitchTab(t.Name)
                        break
                    else
                        self:SwitchTab("⚙️ Настройки")
                    end
                end
            end
            
            self:ShowNotification("🗑️ Вкладка удалена: " .. name)
            return true
        end
    end
    return false
end

function Window:GetTab(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then return tab end
    end
    return nil
end

function Window:GetTabNames()
    local names = {}
    for _, tab in ipairs(self.Tabs) do
        table.insert(names, tab.Name)
    end
    return names
end

function Window:SwitchTab(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            tab.Content.Visible = true
            TweenService:Create(tab.Button, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.TabActive}):Play()
            tab.Button.TextColor3 = self.Theme.Text
            self.CurrentTab = tab
            
            if self.TabCallbacks[name] then
                self.TabCallbacks[name]()
            end
        else
            tab.Content.Visible = false
            tab.Button.BackgroundColor3 = self.Theme.TabInactive
            tab.Button.TextColor3 = self.Theme.TextDim
        end
    end
end

function Window:OnTabSelect(tabName, callback)
    self.TabCallbacks[tabName] = callback
end

