-- === ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ===
local function MakeDraggable(frame, handle)
    local dragging, dragStart, startPos = false, nil, nil
    handle = handle or frame
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    handle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

local function CreateCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = parent
    return corner
end

local function CreateStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or YellowTheme.Border
    stroke.Thickness = thickness or 1
    stroke.Parent = parent
    return stroke
end

-- === МЕНЕДЖЕР КОНФИГОВ ===
local ConfigManager = {}
ConfigManager.__index = ConfigManager

function ConfigManager.new(window)
    local self = setmetatable({}, ConfigManager)
    self.Window = window
    self.Config = {}
    self.ConfigName = "Default"
    self.AutoSaveEnabled = true
    self.AutoSaveInterval = 30 -- секунды
    return self
end

function ConfigManager:Set(key, value)
    self.Config[key] = value
    if self.AutoSaveEnabled then
        self:QueueSave()
    end
end

function ConfigManager:Get(key, default)
    if self.Config[key] == nil then
        self.Config[key] = default
    end
    return self.Config[key]
end

function ConfigManager:QueueSave()
    if self._saveQueued then return end
    self._saveQueued = true
    task.delay(1, function()
        self._saveQueued = false
        self:Save(self.ConfigName)
    end)
end

function ConfigManager:Save(name)
    name = name or self.ConfigName
    local data = {
        _version = "3.0",
        _timestamp = os.time(),
        _tabs = self.Window:GetTabNames(),
        values = {}
    }
    
    for k, v in pairs(self.Config) do
        if not k:find("^_") then -- не сохраняем системные ключи
            data.values[k] = v
        end
    end
    
    local success, err = pcall(function()
        local json = HttpService:JSONEncode(data)
        writefile("YellowUI_" .. name .. ".json", json)
    end)
    
    if success then
        print("[YellowUI] Конфиг сохранён:", name)
        return true
    else
        warn("[YellowUI] Ошибка сохранения:", err)
        return false
    end
end

function ConfigManager:Load(name)
    name = name or self.ConfigName
    local success, result = pcall(function()
        return readfile("YellowUI_" .. name .. ".json")
    end)
    
    if success and result then
        local data = HttpService:JSONDecode(result)
        if data.values then
            for k, v in pairs(data.values) do
                self.Config[k] = v
            end
        end
        print("[YellowUI] Конфиг загружен:", name)
        return data
    end
    return nil
end

function ConfigManager:Delete(name)
    pcall(function()
        delfile("YellowUI_" .. name .. ".json")
    end)
end

function ConfigManager:GetAllConfigs()
    local configs = {}
    local success, files = pcall(function()
        return listfiles("") -- или getgenv().listfiles если доступно
    end)
    
    if success and files then
        for _, file in ipairs(files) do
            if file:find("YellowUI_") and file:find("%.json$") then
                local name = file:gsub("YellowUI_", ""):gsub("%.json", "")
                table.insert(configs, name)
            end
        end
    end
    return configs
end

function ConfigManager:StartAutoSave()
    task.spawn(function()
        while self.AutoSaveEnabled and self.Window do
            task.wait(self.AutoSaveInterval)
            if self.Window then
                self:Save(self.ConfigName)
            end
        end
    end)
end

