-- === ВСПОМОГАТЕЛЬНЫЕ МЕТОДЫ ===

function Window:RefreshAllElements()
    for key, elements in pairs(self.Elements) do
        local value = self.Config:Get(key)
        for _, elem in ipairs(elements) do
            if elem.type == "toggle" then
                elem.bg.BackgroundColor3 = value and self.Theme.ToggleOn or self.Theme.ToggleOff
                elem.knob.Position = value and UDim2.new(1, -26, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
            elseif elem.type == "slider" then
                local percent = math.clamp((value - elem.min) / (elem.max - elem.min), 0, 1)
                elem.fill.Size = UDim2.new(percent, 0, 1, 0)
                elem.knob.Position = UDim2.new(percent, -9, 0.5, -9)
                elem.label.Text = elem.label.Text:gsub(": .*", ": " .. tostring(value))
            end
        end
    end
end

function Window:ShowNotification(text, duration)
    duration = duration or 2
    
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 250, 0, 45)
    notif.Position = UDim2.new(0.5, -125, 0, -60)
    notif.BackgroundColor3 = self.Theme.TabActive
    notif.Text = text
    notif.TextColor3 = self.Theme.Text
    notif.TextSize = 14
    notif.Font = Enum.Font.GothamBold
    notif.Parent = self.Frame
    CreateCorner(notif, 10)
    CreateStroke(notif, self.Theme.Border, 2)
    
    -- Анимация появления
    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -125, 0, 15)}):Play()
    
    task.delay(duration, function()
        TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -125, 0, -60)}):Play()
        task.wait(0.3)
        notif:Destroy()
    end)
end

function Window:ToggleVisibility()
    self.Frame.Visible = not self.Frame.Visible
    if self.MinFrame then
        self.MinFrame.Visible = not self.Frame.Visible
    end
end

function Window:Minimize()
    if self.Minimized then return end
    self.Minimized = true
    
    self.MinFrame = Instance.new("Frame")
    self.MinFrame.Size = UDim2.new(0, 160, 0, 50)
    self.MinFrame.Position = UDim2.new(0, 20, 0, 20)
    self.MinFrame.BackgroundColor3 = self.Theme.TitleBar
    self.MinFrame.BorderSizePixel = 0
    self.MinFrame.Parent = self.ScreenGui
    CreateCorner(self.MinFrame, 12)
    CreateStroke(self.MinFrame, self.Theme.Border, 2)
    
    local minText = Instance.new("TextLabel")
    minText.Size = UDim2.new(1, 0, 1, 0)
    minText.BackgroundTransparency = 1
    minText.Text = "🟡 YellowUI"
    minText.TextColor3 = self.Theme.Text
    minText.TextSize = 16
    minText.Font = Enum.Font.GothamBold
    minText.Parent = self.MinFrame
    
    local restoreBtn = Instance.new("TextButton")
    restoreBtn.Size = UDim2.new(1, 0, 1, 0)
    restoreBtn.BackgroundTransparency = 1
    restoreBtn.Text = ""
    restoreBtn.Parent = self.MinFrame
    
    MakeDraggable(self.MinFrame)
    
    restoreBtn.MouseButton1Click:Connect(function()
        self.Minimized = false
        self.Frame.Visible = true
        self.MinFrame:Destroy()
        self.MinFrame = nil
    end)
    
    self.Frame.Visible = false
end

function Window:Destroy()
    self.Config.AutoSaveEnabled = false
    self.ScreenGui:Destroy()
    if self.MinFrame then self.MinFrame:Destroy() end
end

