-- === ХОТКЕИ ===
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Insert - показать/скрыть
    if input.KeyCode == Enum.KeyCode.Insert then
        if minimized and minFrame then
            minimized = false
            frame.Visible = true
            minFrame:Destroy()
            minFrame = nil
        else
            frame.Visible = not frame.Visible
        end
    end
    
    -- Фиксация цели
    if Config.Keybinds["Target Lock"] and input.KeyCode == Config.Keybinds["Target Lock"] then
        if lockedTarget then
            lockedTarget = nil
        else
            lockedTarget = getTarget()
        end
    end
    
    -- Остальные бинды
    for funcName, keyCode in pairs(Config.Keybinds) do
        if keyCode and input.KeyCode == keyCode and funcName ~= "Target Lock" then
            if Config[funcName] ~= nil and type(Config[funcName]) == "boolean" then
                Config[funcName] = not Config[funcName]
                updateToggleVisual(funcName, Config[funcName])
            end
        end
    end
end)

