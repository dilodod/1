    CreateCorner(self.MinFrame, 10)
    CreateStroke(self.MinFrame, self.Theme.Border, 2)
    
    local minText = Instance.new("TextLabel")
    minText.Size = UDim2.new(1, 0, 1, 0)
    minText.BackgroundTransparency = 1
