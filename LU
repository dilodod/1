    header.Size = UDim2.new(1, 0, 0, 24)
    header.BackgroundColor3 = Color3.fromRGB(255, 235, 100)
    Instance.new("UICorner", header).CornerRadius = UDim.new(0, 5)
    
    local title = Instance.new("TextLabel", header)
    title.Size = UDim2.new(1, -10, 1, 0)
    title.Position = UDim2.new(0, 8, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = "ИГРОКИ [Клик: Игнор -> Цель -> Нет]"
    title.TextColor3 = Color3.fromRGB(0, 0, 0)
    title.TextSize = 10
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    
    local s = Instance.new("ScrollingFrame", c)
    s.Size = UDim2.new(1, -10, 1, -54)
    s.Position = UDim2.new(0, 5, 0, 26)
    s.BackgroundColor3 = Color3.fromRGB(255, 255, 200)
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 3
    
    local list = Instance.new("UIListLayout", s)
    list.Padding = UDim.new(0, 2)
    
    local function update()
        for _, ch in pairs(s:GetChildren()) do
            if ch:IsA("TextButton") then ch:Destroy() end
        end
        
        local allPlayers = {}
        for _, pl in pairs(Players:GetPlayers()) do
            if pl ~= player then
                table.insert(allPlayers, pl)
            end
        end
        
        table.sort(allPlayers, function(a, b)
            return a.Name:lower() < b.Name:lower()
        end)
        
        for _, pl in pairs(allPlayers) do
            local dist = math.huge
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
                dist = (pl.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            end
            
            local isWhitelisted = Config.Whitelist[pl.UserId] == true
            local isTargeted = Config.Targets[pl.UserId] == true
            
            local b = Instance.new("TextButton", s)
            b.Size = UDim2.new(1, -4, 0, 24)
            
            if isWhitelisted then
                b.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            elseif isTargeted then
                b.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
            else
                b.BackgroundColor3 = Color3.fromRGB(255, 255, 100)
            end
            
            local status = ""
            if isWhitelisted then status = " [ИГНОР]"
            elseif isTargeted then status = " [ЦЕЛЬ]" end
            
            b.Text = pl.Name .. " [" .. math.floor(dist) .. "м]" .. status
            b.TextColor3 = Color3.fromRGB(0, 0, 0)
            b.TextSize = 9
            b.Font = Enum.Font.Gotham
            
            b.MouseButton1Click:Connect(function()
                if not isWhitelisted and not isTargeted then
                    Config.Whitelist[pl.UserId] = true
                elseif isWhitelisted and not isTargeted then
                    Config.Whitelist[pl.UserId] = nil
                    Config.Targets[pl.UserId] = true
                else
                    Config.Whitelist[pl.UserId] = nil
                    Config.Targets[pl.UserId] = nil
                end
                update()
            end)
        end
        
        s.CanvasSize = UDim2.new(0, 0, 0, list.AbsoluteContentSize.Y)
    end
    
    update()
    task.spawn(function()
        while task.wait(0.5) do
            if currentTab == "TARGET" then update() end
        end
    end)
    
    local btnFrame = Instance.new("Frame", c)
    btnFrame.Size = UDim2.new(1, -10, 0, 22)
    btnFrame.Position = UDim2.new(0, 5, 1, -24)
    btnFrame.BackgroundTransparency = 1
    
    local clearAll = Instance.new("TextButton", btnFrame)
    clearAll.Size = UDim2.new(1, 0, 1, 0)
    clearAll.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    clearAll.Text = "Очистить всё"
    clearAll.TextColor3 = Color3.fromRGB(0, 0, 0)
    clearAll.TextSize = 10
    clearAll.Font = Enum.Font.GothamBold
    Instance.new("UICorner", clearAll).CornerRadius = UDim.new(0, 4)
    
    clearAll.MouseButton1Click:Connect(function()
        Config.Whitelist = {}
        Config.Targets = {}
        update()
    end)
    
    return c
end

