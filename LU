-- LocalScript в StarterPlayerScripts
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local localPlayer = Players.LocalPlayer

repeat task.wait() until localPlayer.Character
local character = localPlayer.Character
repeat task.wait() until character:FindFirstChild("HumanoidRootPart")
local hrp = character:WaitForChild("HumanoidRootPart")

-- === НАСТРОЙКИ ===
local SKILL_NAME = "Lethal Whirlwind Stream"
local CHECK_RADIUS = 3
local LIVE_FOLDER = "Live"
local COOLDOWN = 20
local RISE_HEIGHT = 7.5      -- 7.5 стадов вверх
local RISE_DURATION = 2      -- 2 секунды подъема
local SPIN_SPEED = 80        -- Еще более сильное кручение (градусов/сек)

local ANIM_SKILL_START = "rbxassetid://12296882427"

-- Цвета
local COLOR_COOLDOWN = Color3.fromRGB(60, 60, 60)
local COLOR_READY = Color3.fromRGB(100, 255, 100)
local COLOR_ANIMATION = Color3.fromRGB(0, 150, 255)  -- Анимация детектед
local COLOR_FORCEFIELD = Color3.fromRGB(150, 0, 255) -- Крутимся
local COLOR_CASTING = Color3.fromRGB(255, 200, 0)

-- === СОСТОЯНИЯ ===
local currentTarget = nil
local lastSkillTime = -COOLDOWN
local skillUsed = false
local hasForceField = false
local dashPending = false
local isSpinning = false
local animationDetected = false

-- === GUI ===
local statusGui = Instance.new("ScreenGui")
statusGui.Name = "SkillStatus"
statusGui.ResetOnSpawn = false
statusGui.Parent = localPlayer:WaitForChild("PlayerGui")

local statusFrame = Instance.new("Frame")
statusFrame.Size = UDim2.new(0, 100, 0, 100)
statusFrame.Position = UDim2.new(0.5, -50, 0.75, 0)
statusFrame.BackgroundColor3 = COLOR_COOLDOWN
statusFrame.BorderSizePixel = 0

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 16)
corner.Parent = statusFrame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Thickness = 4
stroke.Parent = statusFrame

local timerLabel = Instance.new("TextLabel")
timerLabel.Size = UDim2.new(1, 0, 0.6, 0)
timerLabel.Position = UDim2.new(0, 0, 0.1, 0)
timerLabel.BackgroundTransparency = 1
timerLabel.Text = "20"
timerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
timerLabel.Font = Enum.Font.GothamBlack
timerLabel.TextSize = 48
timerLabel.Parent = statusFrame

local statusTextLabel = Instance.new("TextLabel")
statusTextLabel.Size = UDim2.new(1, 0, 0.3, 0)
statusTextLabel.Position = UDim2.new(0, 0, 0.7, 0)
statusTextLabel.BackgroundTransparency = 1
statusTextLabel.Text = "INIT"
statusTextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
statusTextLabel.Font = Enum.Font.GothamBold
statusTextLabel.TextSize = 16
statusTextLabel.Parent = statusFrame

statusFrame.Parent = statusGui

local function setColor(color, text)
    statusFrame.BackgroundColor3 = color
    statusTextLabel.Text = text
end

-- === ПОИСК ЦЕЛИ ===
local function getNearestTarget()
    local live = Workspace:FindFirstChild(LIVE_FOLDER)
    if not live then return nil end
    
    local nearest = nil
    local minDist = CHECK_RADIUS
    
    for _, obj in pairs(live:GetChildren()) do
        if obj ~= character and obj:IsA("Model") then
            local otherHrp = obj:FindFirstChild("HumanoidRootPart")
            if otherHrp then
                local dist = (hrp.Position - otherHrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = {
                        Model = obj,
                        HRP = otherHrp,
                        Distance = dist
                    }
                end
            end
        end
    end
    return nearest
end

local function checkForceField()
    if not currentTarget or not currentTarget.Model then return false end
    return currentTarget.Model:FindFirstChild("ForceField") ~= nil
end

-- === МЕГА ВЕРТУШКА (только пока есть ForceField) ===
local function megaSpinLoop()
    if isSpinning then return end
    isSpinning = true
    
    print("🌪️ MEGA SPIN START!")
    setColor(COLOR_FORCEFIELD, "SPIN!")
    
    local startTime = tick()
    local startY = hrp.Position.Y
    
    while isSpinning do
        -- ПРОВЕРЯЕМ: если ForceField пропал — останавливаемся
        if not checkForceField() then
            print("⚠️ ForceField lost — spin stopped")
            isSpinning = false
            break
        end
        
        local elapsed = tick() - startTime
        
        -- Подъем 7.5 стадов за 2 секунды
        local progress = math.min(elapsed / RISE_DURATION, 1)
        local newY = startY + (RISE_HEIGHT * progress)
        
        -- Супер быстрое кручение
        local spinAngle = elapsed * SPIN_SPEED
        
        -- Ориентация на цель во время кручения
        local targetDir = Vector3.new(0, 0, 1)
        if currentTarget and currentTarget.HRP then
            local targetPos = currentTarget.HRP.Position
            local myPos = hrp.Position
            targetDir = Vector3.new(targetPos.X - myPos.X, 0, targetPos.Z - myPos.Z).Unit
        end
        
        -- Крутим вокруг оси Y + смотрим на цель
        local rotatedDir = CFrame.Angles(0, math.rad(spinAngle), 0) * targetDir
        
        hrp.CFrame = CFrame.new(
            Vector3.new(hrp.Position.X, newY, hrp.Position.Z),
            Vector3.new(hrp.Position.X, newY, hrp.Position.Z) + rotatedDir
        )
        
        RunService.Heartbeat:Wait()
    end
    
    print("🌪️ MEGA SPIN ENDED")
end

-- === DASH+Q ===
local function triggerDashQ()
    print("⚡ Dash+Q")
    
    local communicate = character:FindFirstChild("Communicate")
    if communicate then
        local args = {
            [1] = {
                ["Dash"] = Enum.KeyCode.W,
                ["Key"] = Enum.KeyCode.Q,
                ["Goal"] = "KeyPress"
            }
        }
        pcall(function()
            communicate:FireServer(unpack(args))
        end)
        
        task.delay(0.1, function()
            local releaseArgs = {
                [1] = {
                    ["Dash"] = Enum.KeyCode.W,
                    ["Key"] = Enum.KeyCode.Q,
                    ["Goal"] = "KeyRelease"
                }
            }
            pcall(function()
                communicate:FireServer(unpack(releaseArgs))
            end)
        end)
    end
end

-- === АКТИВАЦИЯ СКИЛЛА ===
local function activateSkill()
    local backpack = localPlayer:WaitForChild("Backpack")
    local tool = backpack:FindFirstChild(SKILL_NAME) or character:FindFirstChild(SKILL_NAME)
    
    if not tool then return false end
    
    if tool.Parent == backpack then
        tool.Parent = character
        task.wait(0.1)
    end
    
    if tool.Parent == character then
        tool:Activate()
        lastSkillTime = tick()
        skillUsed = true
        dashPending = true
        animationDetected = false
        print("✅ Skill activated")
        return true
    end
    
    return false
end

-- === ОТСЛЕЖИВАНИЕ АНИМАЦИИ ===
local function setupAnimationTracking()
    local humanoid = character:WaitForChild("Humanoid")
    local animator = humanoid:WaitForChild("Animator")
    
    animator.AnimationPlayed:Connect(function(track)
        local animId = track.Animation and track.Animation.AnimationId
        
        if animId == ANIM_SKILL_START then
            animationDetected = true
            print("🔵 Animation detected — skill is active")
            setColor(COLOR_ANIMATION, "ANIM!")
            
            -- Анимация просто индикатор, ничего не делаем
            track.Stopped:Connect(function()
                print("🔵 Animation ended")
                -- Не сбрасываем цвет здесь, ждем ForceField
            end)
        end
    end)
end

-- === ГЛАВНЫЙ ЦИКЛ ===
print("✅ SCRIPT STARTED")

setupAnimationTracking()
setColor(COLOR_READY, "READY")

RunService.Heartbeat:Connect(function()
    -- Если крутимся — проверяем ForceField внутри цикла
    if isSpinning then return end
    
    local now = tick()
    local cdLeft = COOLDOWN - (now - lastSkillTime)
    
    if cdLeft > 0 then
        timerLabel.Text = tostring(math.ceil(cdLeft))
    else
        timerLabel.Text = "GO"
    end
    
    local ffNow = checkForceField()
    
    -- ForceField ПОЯВИЛСЯ и мы его еще не обрабатывали
    if ffNow and not hasForceField then
        hasForceField = true
        print("🟣 ForceField APPEARED — START SPIN!")
        
        -- Запускаем вертушку (она сама проверит FF)
        task.spawn(megaSpinLoop)
        return
    end
    
    -- ForceField пропал во время ожидания
    if hasForceField and not ffNow then
        hasForceField = false
        print("⚪ ForceField GONE!")
        
        if skillUsed and dashPending then
            triggerDashQ()
            skillUsed = false
            dashPending = false
        end
        
        setColor(COLOR_READY, "READY")
        return
    end
    
    -- FF есть и мы крутимся — ждем окончания
    if ffNow and hasForceField then
        return
    end
    
    -- Обычное состояние
    if cdLeft > 0 then
        setColor(COLOR_COOLDOWN, "CD")
    else
        setColor(COLOR_READY, "READY")
    end
    
    if cdLeft > 0 then return end
    
    -- Ищем цель
    currentTarget = getNearestTarget()
    if not currentTarget then 
        setColor(COLOR_COOLDOWN, "NO TARGET")
        return 
    end
    
    -- Поворачиваемся к цели
    local targetPos = currentTarget.HRP.Position
    local myPos = hrp.Position
    local dir = Vector3.new(targetPos.X - myPos.X, 0, targetPos.Z - myPos.Z).Unit
    hrp.CFrame = CFrame.new(myPos, myPos + dir)
    
    setColor(COLOR_CASTING, "CAST!")
    activateSkill()
end)

-- === СБРОС ===
localPlayer.CharacterAdded:Connect(function(newChar)
    print("🔄 Respawn")
    character = newChar
    hrp = newChar:WaitForChild("HumanoidRootPart")
    
    currentTarget = nil
    lastSkillTime = -COOLDOWN
    skillUsed = false
    hasForceField = false
    dashPending = false
    isSpinning = false
    animationDetected = false
    
    task.wait(0.5)
    setupAnimationTracking()
    setColor(COLOR_READY, "READY")
end)
