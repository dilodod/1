end

function Window:BindConfig(configTable)
    self.Config = configTable or {}
    -- Загружаем сохранённые вкладки если есть
    if self.Config._savedTabs then
        self.SavedTabs = self.Config._savedTabs
    end
    return self
end

-- === УПРАВЛЕНИЕ ВКЛАДКАМИ (БЕЗ ДУБЛИКАТОВ) ===

function Window:CreateTab(name, onSelect)
    -- Проверяем существует ли уже такая вкладка
    for i, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            -- Обновляем существующую вкладку
            tab._onSelect = onSelect
            print("[YellowUI] Вкладка '" .. name .. "' уже существует, обновлена")
            return tab
        end
    end
    
    -- Создаём новую вкладку
    local tab = {}
    tab.Name = name
    tab.Window = self
    tab.Content = nil
    tab.Button = nil
    tab.Items = {}
    tab._onSelect = onSelect
    
    -- Кнопка таба
    local btn = Instance.new("TextButton")
    btn.Name = "Tab_" .. name
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.BackgroundColor3 = self.Theme.TabInactive
    btn.Text = "  " .. name
    btn.TextColor3 = self.Theme.TextDim
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = self.Sidebar
    CreateCorner(btn, 6)
    CreateStroke(btn, self.Theme.Border, 1)
    
    -- Кнопка удаления
    local deleteBtn = Instance.new("TextButton")
    deleteBtn.Name = "DeleteBtn"
    deleteBtn.Size = UDim2.new(0, 22, 0, 22)
    deleteBtn.Position = UDim2.new(1, -24, 0.5, -11)
    deleteBtn.BackgroundColor3 = self.Theme.Close
    deleteBtn.Text = "×"
    deleteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    deleteBtn.TextSize = 14
    deleteBtn.Font = Enum.Font.GothamBold
    deleteBtn.Visible = false
    deleteBtn.Parent = btn
    CreateCorner(deleteBtn, 4)
    
    tab.Button = btn
    tab.DeleteBtn = deleteBtn
    
    -- Контент таба
    local content = Instance.new("Frame")
    content.Name = name
    content.Size = UDim2.new(1, -10, 0, 0)
    content.Position = UDim2.new(0, 5, 0, 0)
    content.BackgroundTransparency = 1
    content.Visible = false
    content.AutomaticSize = Enum.AutomaticSize.Y
    content.Parent = self.Content
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 6)
    listLayout.Parent = content
    
    tab.Content = content
    
    -- Переключение
    btn.MouseButton1Click:Connect(function()
        self:SwitchTab(name)
    end)
    
    -- Показать/скрыть удаление
    btn.MouseEnter:Connect(function()
        deleteBtn.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(255, 230, 100)
    end)
    btn.MouseLeave:Connect(function()
        deleteBtn.Visible = false
        if self.CurrentTab ~= tab then
            btn.BackgroundColor3 = self.Theme.TabInactive
        end
    end)
    
    -- Удаление
    deleteBtn.MouseButton1Click:Connect(function()
        self:RemoveTab(name)
    end)
    
    table.insert(self.Tabs, tab)
    
    -- Авто-выбор первого
    if #self.Tabs == 1 then
        self:SwitchTab(name)
    end
    
    print("[YellowUI] Создана вкладка: " .. name)
    return tab
end

function Window:RemoveTab(name)
    for i, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            tab.Button:Destroy()
            tab.Content:Destroy()
            table.remove(self.Tabs, i)
            
            -- Пересчёт позиций
            for j, t in ipairs(self.Tabs) do
                -- UIListLayout сам управляет позициями в ScrollingFrame
            end
            
            if self.CurrentTab and self.CurrentTab.Name == name then
                if #self.Tabs > 0 then
                    self:SwitchTab(self.Tabs[1].Name)
                else
                    self.CurrentTab = nil
                end
            end
            
            print("[YellowUI] Удалена вкладка: " .. name)
            return true
        end
    end
    return false
end

function Window:GetTab(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then return tab end
    end
    return nil
end

function Window:SwitchTab(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            tab.Content.Visible = true
            tab.Button.BackgroundColor3 = self.Theme.TabActive
            tab.Button.TextColor3 = self.Theme.Text
            self.CurrentTab = tab
            
            if tab._onSelect then tab._onSelect() end
            if self.TabCallbacks[name] then self.TabCallbacks[name]() end
        else
            tab.Content.Visible = false
            tab.Button.BackgroundColor3 = self.Theme.TabInactive
            tab.Button.TextColor3 = self.Theme.TextDim
        end
    end
end

function Window:OnTabSelect(tabName, callback)
    self.TabCallbacks[tabName] = callback
end

-- === СОХРАНЕНИЕ СТРУКТУРЫ ВКЛАДОК ===

function Window:SaveTabsStructure()
    local tabNames = {}
    for _, tab in ipairs(self.Tabs) do
        table.insert(tabNames, tab.Name)
    end
    
    self.Config._savedTabs = tabNames
    
    -- Визуальный фидбек
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 200, 0, 40)
    notif.Position = UDim2.new(0.5, -100, 0, -50)
    notif.BackgroundColor3 = self.Theme.TabActive
    notif.Text = "💾 Вкладки сохранены!"
    notif.TextColor3 = self.Theme.Text
    notif.TextSize = 14
    notif.Font = Enum.Font.GothamBold
    notif.Parent = self.Frame
    CreateCorner(notif, 8)
    CreateStroke(notif, self.Theme.Border, 2)
    
    TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -100, 0, 10)}):Play()
    task.wait(2)
    TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -100, 0, -50)}):Play()
    task.wait(0.3)
    notif:Destroy()
    
    print("[YellowUI] Сохранены вкладки:", table.concat(tabNames, ", "))
end

function Window:RestoreSavedTabs()
    if not self.Config._savedTabs then return end
    
    for _, tabName in ipairs(self.Config._savedTabs) do
        self:CreateTab(tabName)
    end
    print("[YellowUI] Восстановлено вкладок: " .. #self.Config._savedTabs)
end

