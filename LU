-- === УТИЛИТЫ ===
local function hasStatus(target, status)
    if not target or not target.Model then return false end
    return target.Model:FindFirstChild(status) ~= nil
end

local function hasComboStun(target) return hasStatus(target, COMBAT.COMBO_STUN) end
local function hasSmallDebris(target) return hasStatus(target, COMBAT.SMALL_DEBRIS) end
local function hasFreeze(target) return hasStatus(target, COMBAT.FREEZE) end
local function hasProjectileCounter(target) 
    return hasStatus(target, COMBAT.PROJECTILE_COUNTER) or hasStatus(target, COMBAT.ATOMIC_COUNTER)
end

local function hasOurRagdoll(char)
    return State.ragdollActive or char:FindFirstChild(COMBAT.RAGDOLL) ~= nil
end

-- === КОМБАТ ФУНКЦИИ ===
local function sendAction(action, key)
    local char = player.Character
    if not char then return end
    local comm = char:FindFirstChild("Communicate")
    if not comm then return end
    
    comm:FireServer({
        ["Goal"] = action,
        ["Key"] = key,
        ["Mobile"] = true
    })
end

local function setBlock(pressed)
    if pressed == State.isBlocking then return end
    if not Config.Block then return end
    
    sendAction(pressed and "KeyPress" or "KeyRelease", Enum.KeyCode.F)
    State.isBlocking = pressed
end

local function doInstantClick()
    if tick() - State.lastAttackTime < Config.AttackDelay then return false end
    if not State.currentTarget then return false end
    if State.currentTarget.Distance > COMBAT.ATTACK_RANGE then return false end
    if not Config.Attack then return false end
    
    State.lastAttackTime = tick()
    sendAction("LeftClick", Enum.UserInputType.MouseButton1)
    task.wait(Config.ClickDuration)
    sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
    
    -- Black Flash
    if Config.BlackFlash and math.random(1, 100) <= Config.BFChance then
        task.wait(0.1)
        sendAction("LeftClick", Enum.UserInputType.MouseButton1)
        task.wait(0.05)
        sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
    end
    
    return true
end

local function isEnemyAttacking(target)
    if not target or not target.Model then return false end
    local char = target.Model
    
    if char:FindFirstChild("M1ing") then return true end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            local name = track.Name:lower()
            if (name:find("punch") or name:find("attack") or name:find("m1") or name:find("swing")) and track.IsPlaying then
                return true
            end
        end
    end
    return false
end

local function rotateToTarget()
    if not Config.Aim then return end
    if hasOurRagdoll(player.Character) then return end
    if not State.currentTarget or not State.currentTarget.HRP then return end
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local targetPos = State.currentTarget.HRP.Position
    local myPos = hrp.Position
    
    local dir
    if Config.AimY then
        dir = (targetPos - myPos).Unit
    else
        dir = Vector3.new(targetPos.X - myPos.X, 0, targetPos.Z - myPos.Z).Unit
    end
    
    local speed = (State.hadDebrisLastFrame and Config.AimFastOnDebris) 
        and Config.AimFastSpeed or Config.AimSpeed
    
    hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(myPos, myPos + dir), speed)
end

-- === ОБНОВЛЕНИЕ ЦЕЛЕЙ ===
local function updateTargetList()
    State.targetList = {}
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local live = Workspace:FindFirstChild("Live")
    if not live then return end
    
    for _, obj in pairs(live:GetChildren()) do
        if obj ~= char and obj:IsA("Model") then
            local otherHrp = obj:FindFirstChild("HumanoidRootPart")
            local otherHum = obj:FindFirstChildOfClass("Humanoid")
            if otherHrp and otherHum and otherHum.Health > 0 then
                local dist = (hrp.Position - otherHrp.Position).Magnitude
                if dist < Config.TargetMaxDistance then
                    local pl = Players:GetPlayerFromCharacter(obj)
                    local isWl = pl and Config.Whitelist[pl.UserId]
                    local isTg = pl and Config.Targets[pl.UserId]
                    
                    table.insert(State.targetList, {
                        Name = obj.Name,
                        Model = obj,
                        HRP = otherHrp,
                        Humanoid = otherHum,
                        Distance = dist,
                        Player = pl,
                        IsWhitelisted = isWl,
                        IsTargeted = isTg,
                    })
                end
            end
        end
    end
    
    -- Сортировка
    if Config.TargetMode == "Nearest" then
        table.sort(State.targetList, function(a, b) return a.Distance < b.Distance end)
    end
    
    -- Приоритет Targets
    table.sort(State.targetList, function(a, b)
        if a.IsTargeted and not b.IsTargeted then return true end
        if not a.IsTargeted and b.IsTargeted then return false end
        return false
    end)
    
    -- Выбор цели
    if not State.currentTarget and #State.targetList > 0 then
        State.currentTarget = State.targetList[1]
    end
    
    if State.currentTarget and State.currentTarget.HRP then
        State.currentTarget.Distance = (hrp.Position - State.currentTarget.HRP.Position).Magnitude
        if State.currentTarget.Distance > Config.TargetMaxDistance then
            State.currentTarget = nil
        end
    end
end

-- === ГЛАВНЫЙ КОМБАТ ЦИКЛ ===
local function combatLoop()
    local now = tick()
    local char = player.Character
    if not char then return end
    
    -- Проверки статусов
    local hasDebrisNow = false
    local hasCounterNow = false
    local hasStunNow = false
    local hasFreezeNow = false
    local attacking = false
    
    if State.currentTarget then
        hasDebrisNow = hasSmallDebris(State.currentTarget)
        hasCounterNow = hasProjectileCounter(State.currentTarget)
        hasStunNow = hasComboStun(State.currentTarget)
        hasFreezeNow = hasFreeze(State.currentTarget)
        attacking = isEnemyAttacking(State.currentTarget)
    end
    
    -- Сброс флагов
    if not hasDebrisNow then State.clickedAfterDebris = false end
    if not hasStunNow then State.clickedAfterStun = false end
    if not hasFreezeNow then State.clickedAfterFreeze = false end
    if not hasCounterNow and now > State.projectileProtectionEndTime then State.clickedAfterCounter = false end
    
    -- Защита от Counter
    if hasCounterNow and Config.BlockCounter then
        State.projectileProtectionEndTime = now + COMBAT.PROTECTION_WINDOW
    end
    
    -- Отпускание блока когда Debris пропал
    if State.hadDebrisLastFrame and not hasDebrisNow then
        if State.isBlocking then
            setBlock(false)
        end
        State.smallDebrisEndTime = now
    end
    
    State.hadDebrisLastFrame = hasDebrisNow
    
    -- Поворот к цели
    rotateToTarget()
    
    -- Обновление целей
    if now % 0.3 < 0.02 then
        updateTargetList()
    end
    
    if not State.currentTarget then
        if State.isBlocking then setBlock(false) end
        State.wasAttacking = false
        return
    end
    
    local timeSinceDebris = now - State.smallDebrisEndTime
    
    -- === ПРИОРИТЕТ 0: ЗАЩИТА ОТ COUNTER ===
    if now < State.projectileProtectionEndTime and Config.BlockCounter then
        if attacking and not State.isBlocking then
            setBlock(true)
        elseif not attacking and State.isBlocking then
            setBlock(false)
        end
        return
    end
    
    -- === ПРИОРИТЕТ 1: SMALL DEBRIS ===
    if hasDebrisNow and Config.BlockDebris then
        if not State.isBlocking then
            setBlock(true)
        end
        if Config.AttackOnDebris and not State.clickedAfterDebris and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterDebris = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 2: 0.5С ПОСЛЕ DEBRIS ===
    if timeSinceDebris < COMBAT.ATTACK_WINDOW and timeSinceDebris > 0 then
        if Config.AttackOnDebris and not State.clickedAfterDebris and not attacking and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterDebris = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 3: COMBOSTUN ===
    if hasStunNow and Config.AttackOnStun then
        if not State.clickedAfterStun and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterStun = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 4: FREEZE ===
    if hasFreezeNow and not attacking and Config.AttackOnFreeze then
        if not State.clickedAfterFreeze and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterFreeze = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 5: ОБЫЧНАЯ ЛОГИКА (БЛОК → КЛИК) ===
    if Config.BlockM1 then
        if attacking and not State.wasAttacking then
            State.wasAttacking = true
            setBlock(true)
        end
        
        if not attacking and State.wasAttacking then
            State.wasAttacking = false
            setBlock(false)
            if State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
                doInstantClick()
            end
        end
    end
end

