    label.Size = UDim2.new(0.4, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 140, 0, 32)
    btn.Position = UDim2.new(1, -148, 0.5, -16)
    btn.BackgroundColor3 = self.Theme.TabInactive
    btn.Text = tostring(self.Config:Get(configKey, options[1] or "Select"))
    btn.TextColor3 = self.Theme.Text
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold
    btn.Parent = frame
    CreateCorner(btn, 6)
    CreateStroke(btn, self.Theme.Border, 1)
    
    local callback = nil
    
    btn.MouseButton1Click:Connect(function()
        local current = self.Config:Get(configKey, options[1])
        local index = 1
        for i, v in ipairs(options) do
            if v == current then index = i; break end
        end
        local nextIndex = (index % #options) + 1
        local newValue = options[nextIndex]
        self.Config:Set(configKey, newValue)
        btn.Text = newValue
        if callback then callback(newValue) end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetValue = function(val)
            self.Config:Set(configKey, val)
            btn.Text = tostring(val)
        end,
        GetValue = function() return self.Config:Get(configKey) end
    }
end

