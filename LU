    label.TextSize = 12
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    -- Input box
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 70, 0, 24)
    input.Position = UDim2.new(1, -76, 0.5, -12)
    input.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    input.Text = tostring(self.Config and self.Config[configKey] or "")
    input.TextColor3 = self.Theme.Text
    input.TextSize = 12
    input.Font = Enum.Font.Gotham
    input.ClearTextOnFocus = false
    input.Parent = frame
    CreateCorner(input, 4)
    
    local callback = nil
    
    input.FocusLost:Connect(function()
        if self.Config then
            local value = input.Text
            
            if isNumber then
                local num = tonumber(value)
                if num then
                    if min and num < min then num = min end
                    if max and num > max then num = max end
                    self.Config[configKey] = num
                    input.Text = tostring(num)
                else
                    input.Text = tostring(self.Config[configKey])
                end
            else
                self.Config[configKey] = value
            end
            
            if callback then
                callback(self.Config[configKey])
            end
            
            self:AutoSave()
        end
    end)
    
    return {
        SetCallback = function(fn)
            callback = fn
            return self
        end
    }
end

