    -- Config Functions
    local function saveConfig(name)
        local data = {}
        for k, v in pairs(Config) do
            if k ~= "Whitelist" and k ~= "Targets" then
                data[k] = v
            end
        end
        data.Whitelist = {}
        data.Targets = {}
        for id, _ in pairs(Config.Whitelist) do
            table.insert(data.Whitelist, id)
        end
        for id, _ in pairs(Config.Targets) do
            table.insert(data.Targets, id)
        end
        
        local json = HttpService:JSONEncode(data)
        local success = pcall(function()
            writefile("LightVuln_" .. name .. ".json", json)
        end)
        return success
    end
    
    local function loadConfig(name)
        local success, result = pcall(function()
            return readfile("LightVuln_" .. name .. ".json")
        end)
        if success and result then
            local data = HttpService:JSONDecode(result)
            for k, v in pairs(data) do
                if k ~= "Whitelist" and k ~= "Targets" then
                    Config[k] = v
                end
            end
            Config.Whitelist = {}
            Config.Targets = {}
            if data.Whitelist then
                for _, id in ipairs(data.Whitelist) do
                    Config.Whitelist[id] = true
                end
            end
            if data.Targets then
                for _, id in ipairs(data.Targets) do
                    Config.Targets[id] = true
                end
            end
            
            -- Обновить UI
            for k, _ in pairs(toggleRefs) do
                updateToggleVisual(k, Config[k])
            end
            return true
        end
        return false
    end
    
    saveBtn.MouseButton1Click:Connect(function()
        local name = nameBox.Text
        if saveConfig(name) then
            statusLabel.Text = "✓ Сохранено: " .. name
            statusLabel.TextColor3 = Color3.fromRGB(100, 150, 100)
        else
            statusLabel.Text = "✗ Ошибка сохранения"
            statusLabel.TextColor3 = Color3.fromRGB(200, 100, 100)
        end
        task.wait(2)
        statusLabel.Text = ""
    end)
    
    loadBtn.MouseButton1Click:Connect(function()
        local name = nameBox.Text
        if loadConfig(name) then
            statusLabel.Text = "✓ Загружено: " .. name
            statusLabel.TextColor3 = Color3.fromRGB(100, 150, 100)
        else
            statusLabel.Text = "✗ Конфиг не найден"
            statusLabel.TextColor3 = Color3.fromRGB(200, 100, 100)
        end
        task.wait(2)
        statusLabel.Text = ""
    end)
    
    delBtn.MouseButton1Click:Connect(function()
        local name = nameBox.Text
        local success = pcall(function()
            delfile("LightVuln_" .. name .. ".json")
        end)
        if success then
            statusLabel.Text = "✓ Удалено: " .. name
            statusLabel.TextColor3 = Color3.fromRGB(100, 150, 100)
        else
            statusLabel.Text = "✗ Ошибка удаления"
            statusLabel.TextColor3 = Color3.fromRGB(200, 100, 100)
        end
        task.wait(2)
        statusLabel.Text = ""
    end)
    
    -- Auto-load default
    task.delay(1, function()
        loadConfig("Default")
    end)
    
    switchTab("MAIN")
    return gui
end

-- === ИНИЦИАЛИЗАЦИЯ ===
local function init()
    -- Создаем GUI
    createGUI()
    
    -- Character events
    localPlayer.CharacterAdded:Connect(function(newChar)
        State.isBlocking = false
        State.wasAttacking = false
        State.freezeActive = false
        State.ragdollActive = false
        State.hadDebrisLastFrame = false
        State.smallDebrisEndTime = 0
        State.projectileProtectionEndTime = 0
        State.currentTarget = nil
        State.clickedAfterDebris = false
        State.clickedAfterStun = false
        State.clickedAfterFreeze = false
        State.clickedAfterCounter = false
        
        newChar.ChildAdded:Connect(function(child)
            if child.Name == COMBAT.FREEZE then State.freezeActive = true end
            if child.Name == COMBAT.RAGDOLL then State.ragdollActive = true end
        end)
        
        newChar.ChildRemoved:Connect(function(child)
            if child.Name == COMBAT.FREEZE then State.freezeActive = false end
            if child.Name == COMBAT.RAGDOLL then State.ragdollActive = false end
        end)
        
        task.delay(0.5, function()
            updateTargetList()
        end)
    end)
    
    -- Main loop
    RunService.Heartbeat:Connect(combatLoop)
    
    print("⚡ LightVulnerability v2.0 Loaded | BLOCK → INSTANT CLICK | AimY: " .. tostring(Config.AimY))
end

init()
