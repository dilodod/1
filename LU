    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.4, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 140, 0, 32)
    btn.Position = UDim2.new(1, -148, 0.5, -16)
    btn.BackgroundColor3 = self.Theme.TabInactive
    btn.Text = tostring(self.Config:Get(key, options[1] or "Выбрать"))
    btn.TextColor3 = self.Theme.Text
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold
    btn.Parent = frame
    CreateCorner(btn, 6)
    CreateStroke(btn, self.Theme.Border, 1)
    
    local callback = nil
    
    btn.MouseButton1Click:Connect(function()
        local current = self.Config:Get(key, options[1])
        local idx = 1
        for i, v in ipairs(options) do
            if v == current then idx = i; break end
        end
        local nextIdx = (idx % #options) + 1
        local newVal = options[nextIdx]
        self.Config:Set(key, newVal)
        btn.Text = newVal
        if callback then callback(newVal) end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetValue = function(val) self.Config:Set(key, val); btn.Text = tostring(val) end,
        GetValue = function() return self.Config:Get(key) end
    }
end

-- ВСПОМОГАТЕЛЬНЫЕ
function Window:RefreshAllElements()
    for key, elems in pairs(self.Elements) do
        local val = self.Config:Get(key)
        for _, elem in ipairs(elems) do
            if elem.type == "toggle" then
                elem.bg.BackgroundColor3 = val and self.Theme.ToggleOn or self.Theme.ToggleOff
                elem.knob.Position = val and UDim2.new(1, -26, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
            elseif elem.type == "slider" then
                local pct = math.clamp((val - elem.min) / (elem.max - elem.min), 0, 1)
                elem.fill.Size = UDim2.new(pct, 0, 1, 0)
                elem.knob.Position = UDim2.new(pct, -9, 0.5, -9)
            end
        end
    end
end

function Window:ShowNotification(text, isError)
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 280, 0, 50)
    notif.Position = UDim2.new(0.5, -140, 0, -70)
    notif.BackgroundColor3 = isError and self.Theme.Error or self.Theme.TabActive
    notif.Text = text
    notif.TextColor3 = self.Theme.Text
    notif.TextSize = 14
    notif.Font = Enum.Font.GothamBold
    notif.Parent = self.Frame
    CreateCorner(notif, 10)
    CreateStroke(notif, self.Theme.Border, 2)
    
    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -140, 0, 20)}):Play()
    
    task.delay(2.5, function()
        TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -140, 0, -70)}):Play()
        task.wait(0.3)
        notif:Destroy()
    end)
end

function Window:ToggleVisibility()
    self.Frame.Visible = not self.Frame.Visible
    if self.MinFrame then
        self.MinFrame.Visible = not self.Frame.Visible
    end
end

function Window:Minimize()
    if self.Minimized then return end
    self.Minimized = true
    
    self.MinFrame = Instance.new("Frame")
    self.MinFrame.Size = UDim2.new(0, 160, 0, 50)
    self.MinFrame.Position = UDim2.new(0, 20, 0, 20)
    self.MinFrame.BackgroundColor3 = self.Theme.TitleBar
    self.MinFrame.Parent = self.ScreenGui
    CreateCorner(self.MinFrame, 12)
    CreateStroke(self.MinFrame, self.Theme.Border, 2)
    
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.Text = "🟡 Меню"
    txt.TextColor3 = self.Theme.Text
    txt.TextSize = 16
    txt.Font = Enum.Font.GothamBold
    txt.Parent = self.MinFrame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Parent = self.MinFrame
    
    MakeDraggable(self.MinFrame)
    
    btn.MouseButton1Click:Connect(function()
        self.Minimized = false
        self.Frame.Visible = true
        self.MinFrame:Destroy()
        self.MinFrame = nil
    end)
    
    self.Frame.Visible = false
end

function Window:Destroy()
    self.Config.AutoSaveEnabled = false
    self.ScreenGui:Destroy()
    if self.MinFrame then self.MinFrame:Destroy() end
end

