function Window:Minimize()
    if self.Minimized then return end
    self.Minimized = true
    
    self.MinFrame = Instance.new("Frame")
    self.MinFrame.Size = UDim2.new(0, 120, 0, 40)
    self.MinFrame.Position = UDim2.new(0, 10, 0, 10)
    self.MinFrame.BackgroundColor3 = self.Theme.TitleBar
    self.MinFrame.BackgroundTransparency = 0.2
    self.MinFrame.Parent = self.ScreenGui
    CreateCorner(self.MinFrame, 8)
    
    local minText = Instance.new("TextLabel")
    minText.Size = UDim2.new(1, 0, 1, 0)
    minText.BackgroundTransparency = 1
    minText.Text = "📋 MENU"
    minText.TextColor3 = self.Theme.Text
    minText.TextSize = 14
    minText.Font = Enum.Font.GothamBold
    minText.Parent = self.MinFrame
    
    local restoreBtn = Instance.new("TextButton")
    restoreBtn.Size = UDim2.new(1, 0, 1, 0)
    restoreBtn.BackgroundTransparency = 1
    restoreBtn.Text = ""
    restoreBtn.Parent = self.MinFrame
    
    MakeDraggable(self.MinFrame)
    
    restoreBtn.MouseButton1Click:Connect(function()
        self.Minimized = false
        self.Frame.Visible = true
        self.MinFrame:Destroy()
        self.MinFrame = nil
    end)
    
    self.Frame.Visible = false
end

function Window:Destroy()
    self.ScreenGui:Destroy()
    if self.MinFrame then
        self.MinFrame:Destroy()
    end
end

