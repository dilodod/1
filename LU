        trashFolder.DescendantAdded:Connect(function()
            task.wait(0.1)
            setupHighlights()
        end)
        trashFolder.DescendantRemoving:Connect(function()
            task.wait(0.1)
            setupHighlights()
        end)
    end
end

createButton()

