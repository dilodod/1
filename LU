    local function updatePlayerList()
        for _, ch in pairs(listScroll:GetChildren()) do
            if ch:IsA("TextButton") then ch:Destroy() end
        end
        
        local allPlayers = {}
        for _, pl in pairs(Players:GetPlayers()) do
            if pl ~= localPlayer then
                table.insert(allPlayers, pl)
            end
        end
        
        table.sort(allPlayers, function(a, b) return a.Name:lower() < b.Name:lower() end)
        
        for _, pl in pairs(allPlayers) do
            local char = pl.Character
            local dist = math.huge
            if char and char:FindFirstChild("HumanoidRootPart") and localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                dist = (char.HumanoidRootPart.Position - localPlayer.Character.HumanoidRootPart.Position).Magnitude
            end
            
            local isWl = isWhitelisted(pl)
            local isTg = isTargeted(pl)
            
            local b = Instance.new("TextButton", listScroll)
            b.Size = UDim2.new(1, -4, 0, 26)
            b.BackgroundColor3 = isWl and Color3.fromRGB(255, 255, 255) or (isTg and Color3.fromRGB(180, 200, 255) or Color3.fromRGB(240, 240, 240))
            b.Text = pl.Name .. " [" .. math.floor(dist) .. "m]" .. (isWl and " [ИГНОР]" or (isTg and " [ЦЕЛЬ]" or ""))
            b.TextColor3 = Color3.fromRGB(80, 80, 80)
            b.TextSize = 10
            b.Font = Enum.Font.Gotham
            b.BorderSizePixel = 0
            
            b.MouseButton1Click:Connect(function()
                if not isWl and not isTg then
                    Config.Whitelist[pl.UserId] = true
                elseif isWl and not isTg then
                    Config.Whitelist[pl.UserId] = nil
                    Config.Targets[pl.UserId] = true
                else
                    Config.Whitelist[pl.UserId] = nil
                    Config.Targets[pl.UserId] = nil
                end
                updatePlayerList()
            end)
        end
        
        listScroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    end
    
