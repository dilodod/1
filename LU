    label.Parent = frame
    
    -- Description label
    if description then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, -100, 0, 22)
        desc.Position = UDim2.new(0, 10, 0, 20)
        desc.BackgroundTransparency = 1
        desc.Text = description
        desc.TextColor3 = self.Theme.TextDim
        desc.TextSize = 9
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.TextWrapped = true
        desc.Parent = frame
    end
    
    -- Toggle background
    local bg = Instance.new("Frame")
    bg.Name = "ToggleBg"
    bg.Size = UDim2.new(0, 40, 0, 20)
    bg.Position = UDim2.new(1, -46, 0.5, -10)
    bg.BackgroundColor3 = (self.Config and self.Config[configKey]) and self.Theme.ToggleOn or self.Theme.ToggleOff
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(255, 255, 255)
    bg.Parent = frame
    CreateCorner(bg, 10)
    
    -- Toggle knob
    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = (self.Config and self.Config[configKey]) and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = bg
    CreateCorner(knob, 8)
    
    -- Сохраняем референс
    self.ToggleRefs[configKey] = {bg = bg, knob = knob}
    
    -- Click handler
    local callback = nil
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if self.Config then
                self.Config[configKey] = not self.Config[configKey]
                
                -- Анимация
                local newState = self.Config[configKey]
                TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = newState and self.Theme.ToggleOn or self.Theme.ToggleOff}):Play()
                TweenService:Create(knob, TweenInfo.new(0.2), {Position = newState and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}):Play()
                
                -- Callback
                if callback then
                    callback(newState)
                end
                
                -- Auto-save
                self:AutoSave()
            end
        end
    end)
    
    return {
        SetCallback = function(fn)
            callback = fn
            return self
        end
    }
end

