function Window:CreateInput(tab, text, key, isNumber, min, max)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 44)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 100, 0, 32)
    input.Position = UDim2.new(1, -108, 0.5, -16)
    input.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    input.Text = tostring(self.Config:Get(key, ""))
    input.TextColor3 = self.Theme.Text
    input.TextSize = 13
    input.Font = Enum.Font.Gotham
    input.Parent = frame
    CreateCorner(input, 6)
    CreateStroke(input, self.Theme.Border, 1)
    
    local callback = nil
    
    input.FocusLost:Connect(function()
        local val = input.Text
        if isNumber then
            local num = tonumber(val)
            if num then
                if min then num = math.max(num, min) end
                if max then num = math.min(num, max) end
                self.Config:Set(key, num)
                input.Text = tostring(num)
            else
                input.Text = tostring(self.Config:Get(key, ""))
            end
        else
            self.Config:Set(key, val)
        end
        if callback then callback(self.Config:Get(key)) end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetText = function(txt) input.Text = tostring(txt) end,
        GetValue = function() return self.Config:Get(key) end
    }
end

function Window:CreateDropdown(tab, text, key, options)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 44)
