-- ============================================
-- HUNTER'S GRASP COMBO SCRIPT
-- ============================================

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- === КОНФИГ ===
local CONFIG = {
    SKILL_NAME = "Lethal Whirlwind Stream",
    SEARCH_RADIUS = 12,
    ANIMATION_HIT = "rbxassetid://12296113986",
    ANIMATION_START = "rbxassetid://12296882427",
    SPIN_SPEED = 0.05,  -- скорость кручения
    SPIN_DURATION = 0.5, -- как долго крутиться
}

-- === ПЕРЕМЕННЫЕ ===
local currentTarget = nil
local isSpinning = false
local animationTracker = {}

-- === ОТСЛЕЖИВАНИЕ АНИМАЦИЙ ===
local function setupAnimationTracker()
    humanoid.AnimationPlayed:Connect(function(animTrack)
        local animId = animTrack.Animation.AnimationId
        animationTracker[animId] = true
        
        -- Сброс через секунду
        task.delay(1, function()
            animationTracker[animId] = nil
        end)
    end)
end

-- Проверка анимации
local function isPlayingAnimation(assetId)
    return animationTracker[assetId] == true
end

-- === ФУНКЦИИ ДЕЙСТВИЙ ===

-- Отправка действия
local function sendAction(goal, key, dash)
    local communicate = character:FindFirstChild("Communicate")
    if not communicate then return end
    
    local args = {
        [1] = {
            ["Goal"] = goal,
            ["Key"] = key,
            ["Dash"] = dash,
            ["Mobile"] = true
        }
    }
    communicate:FireServer(unpack(args))
end

-- Dash + Q комбо
local function dashQ(direction)
    direction = direction or Enum.KeyCode.W
    
    sendAction("KeyPress", Enum.KeyCode.Q, direction)
    
    task.delay(0.1, function()
        sendAction("KeyRelease", Enum.KeyCode.Q, direction)
    end)
end

-- Dash вверх (подкидывание)
local function dashUp()
    -- Смотрим вверх
    local lookUp = CFrame.new(hrp.Position, hrp.Position + Vector3.new(0, 10, 0))
    hrp.CFrame = lookUp
    
    -- Небольшой импульс вверх
    hrp.Velocity = Vector3.new(0, 40, 0)
    
    -- Dash вверх (W + смотрим вверх)
    dashQ(Enum.KeyCode.W)
end

-- === ПОИСК ЦЕЛИ ===
local function getNearestTarget(radius)
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    
    local nearest = nil
    local minDist = radius
    
    for _, obj in pairs(live:GetChildren()) do
        if obj ~= character and obj:IsA("Model") then
            local targetHrp = obj:FindFirstChild("HumanoidRootPart")
            local targetHumanoid = obj:FindFirstChild("Humanoid")
            
            if targetHrp and targetHumanoid and targetHumanoid.Health > 0 then
                local dist = (hrp.Position - targetHrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = {
                        Model = obj,
                        HRP = targetHrp,
                        Humanoid = targetHumanoid
                    }
                end
            end
        end
    end
    
    return nearest
end

-- === ПРОВЕРКИ СОСТОЯНИЙ ===
local function hasForceField(target)
    return target:FindFirstChild("ForceField") ~= nil
end

-- === ПОВОРОТ И АИМ ===
local function lookAt(targetPos)
    local pos = hrp.Position
    local dir = Vector3.new(targetPos.X - pos.X, 0, targetPos.Z - pos.Z).Unit
    hrp.CFrame = CFrame.new(pos, pos + dir)
end

-- Аимбот (непрерывно следит)
local function aimbot(targetHRP)
    if not targetHRP then return end
    
    task.spawn(function()
        while targetHRP.Parent and targetHRP.Parent:FindFirstChild("Humanoid") 
              and targetHRP.Parent.Humanoid.Health > 0 do
            lookAt(targetHRP.Position)
            task.wait(0.03)
        end
    end)
end

-- === РАНДОМНОЕ КРУЧЕНИЕ ===
local function randomSpin()
    isSpinning = true
    
    task.spawn(function()
        local startTime = tick()
        
        while isSpinning and (tick() - startTime < CONFIG.SPIN_DURATION) do
            -- Резкие рандомные повороты
            local randomAngle = math.random(-180, 180)
            local randomTilt = math.random(-45, 45)
            
            hrp.CFrame = hrp.CFrame 
                * CFrame.Angles(0, math.rad(randomAngle), 0)
                * CFrame.Angles(math.rad(randomTilt), 0, 0)
            
            -- Микро-движения для хаоса
            hrp.Velocity = Vector3.new(
                math.random(-20, 20),
                math.random(-10, 10),
                math.random(-20, 20)
            )
            
            task.wait(CONFIG.SPIN_SPEED)
        end
        
        isSpinning = false
    end)
end

-- === АКТИВАЦИЯ СКИЛЛА ===
local function activateSkill()
    local tool = player.Backpack:FindFirstChild(CONFIG.SKILL_NAME) 
                 or character:FindFirstChild(CONFIG.SKILL_NAME)
    
    if not tool then return false end
    
    if tool.Parent == player.Backpack then
        tool.Parent = character
        task.wait(0.1)
    end
    
    if tool.Parent == character then
        tool:Activate()
        return true
    end
    
    return false
end

-- ============================================
-- ГЛАВНАЯ ЛОГИКА КОМБО
-- ============================================

local function executeCombo()
    -- 1. Найти цель
    currentTarget = getNearestTarget(CONFIG.SEARCH_RADIUS)
    if not currentTarget then
        print("Цель не найдена")
        return
    end
    
    print("Найдена цель:", currentTarget.Model.Name)
    
    -- 2. Повернуться к цели
    lookAt(currentTarget.HRP.Position)
    
    -- 3. Активировать скилл
    if not activateSkill() then
        print("Скилл не активирован")
        return
    end
    
    print("Скилл активирован")
    
    -- 4. Ждём анимацию начала скилла
    local skillStarted = false
    local startTime = tick()
    
    while tick() - startTime < 2 do
        if isPlayingAnimation(CONFIG.ANIMATION_START) then
            skillStarted = true
            print("Скилл начал работать")
            break
        end
        task.wait(0.05)
    end
    
    if not skillStarted then
        print("Скилл не сработал")
        return
    end
    
    -- 5. Ждём успешного захвата (ForceField + анимация попадания)
    local grabSuccess = false
    startTime = tick()
    
    while tick() - startTime < 3 do
        local hasFF = hasForceField(currentTarget.Model)
        local hitAnim = isPlayingAnimation(CONFIG.ANIMATION_HIT)
        
        if hasFF and hitAnim then
            grabSuccess = true
            print("Успешный захват!")
            break
        end
        task.wait(0.05)
    end
    
    if not grabSuccess then
        print("Захват не удался")
        return
    end
    
    -- 6. Крутимся рандомно и резко пока есть ForceField
    randomSpin()
    
    -- Ждём пока ForceField не пропадёт
    while hasForceField(currentTarget.Model) and isSpinning do
        task.wait(0.1)
    end
    
    -- Останавливаем кручение
    isSpinning = false
    print("ForceField пропал, продолжаем комбо")
    
    -- 7. Dash вверх (подкидывание)
    dashUp()
    task.wait(0.2)
    
    -- 8. Аимбот на цель
    aimbot(currentTarget.HRP)
    
    print("Комбо завершено!")
end

-- ============================================
-- ЗАПУСК
-- ============================================

setupAnimationTracker()

-- Запуск по команде (можно изменить на клавишу)
executeCombo()

