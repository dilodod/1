-- === УТИЛИТЫ ===
local function hasStatus(target, status)
    if not target or not target.Model then return false end
    return target.Model:FindFirstChild(status) ~= nil
end

local function hasComboStun(target) return hasStatus(target, COMBAT.COMBO_STUN) end
local function hasSmallDebris(target) return hasStatus(target, COMBAT.SMALL_DEBRIS) end
local function hasFreeze(target) return hasStatus(target, COMBAT.FREEZE) end
local function hasProjectileCounter(target) 
    return hasStatus(target, COMBAT.PROJECTILE_COUNTER) or hasStatus(target, COMBAT.ATOMIC_COUNTER)
end

local function hasOurRagdoll(char)
    return State.ragdollActive or char:FindFirstChild(COMBAT.RAGDOLL) ~= nil
end

local function isWhitelisted(player)
    return Config.Whitelist[player.UserId] == true
end

local function isTargeted(player)
    return Config.Targets[player.UserId] == true
end

-- === КОМБАТ ФУНКЦИИ ===
local function sendAction(action, key)
    local char = localPlayer.Character
    if not char then return end
    local comm = char:FindFirstChild("Communicate")
    if not comm then return end
    
    comm:FireServer({
        ["Goal"] = action,
        ["Key"] = key,
        ["Mobile"] = true
    })
end

local function setBlock(pressed)
    if pressed == State.isBlocking then return end
    if not Config.Block then return end
    
    sendAction(pressed and "KeyPress" or "KeyRelease", Enum.KeyCode.F)
    State.isBlocking = pressed
end

local function doInstantClick()
    if tick() - State.lastAttackTime < Config.AttackDelay then return false end
    if not State.currentTarget then return false end
    if State.currentTarget.Distance > COMBAT.ATTACK_RANGE then return false end
    if not Config.Attack then return false end
    
    State.lastAttackTime = tick()
    sendAction("LeftClick", Enum.UserInputType.MouseButton1)
    task.wait(Config.ClickDuration)
    sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
    
    -- Black Flash chance
    if Config.BlackFlash and math.random(1, 100) <= Config.BFChance then
        task.wait(0.1)
        sendAction("LeftClick", Enum.UserInputType.MouseButton1)
        task.wait(0.05)
        sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
    end
    
    return true
end

local function isEnemyAttacking(target)
    if not target or not target.Model then return false end
    local char = target.Model
    
    if char:FindFirstChild("M1ing") then return true end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            local name = track.Name:lower()
            if (name:find("punch") or name:find("attack") or name:find("m1") or name:find("swing")) and track.IsPlaying then
                return true
            end
        end
    end
    return false
end

local function rotateToTarget()
    if not Config.Aim then return end
    if not Config.Enabled then return end
    if hasOurRagdoll(localPlayer.Character) then return end
    if not State.currentTarget or not State.currentTarget.HRP then return end
    
    local char = localPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local targetPos = State.currentTarget.HRP.Position
    local myPos = hrp.Position
    
    local dir = Vector3.new(targetPos.X - myPos.X, 0, targetPos.Z - myPos.Z).Unit
    local targetCFrame = CFrame.new(myPos, myPos + dir)
    
    if Config.AimY then
        dir = (targetPos - myPos).Unit
        targetCFrame = CFrame.new(myPos, myPos + dir)
    end
    
    if Config.AimSmoothing then
        local currentSpeed = (State.hadDebrisLastFrame and Config.AimFastOnDebris) 
            and Config.AimFastSpeed or Config.AimSpeed
        hrp.CFrame = hrp.CFrame:Lerp(targetCFrame, currentSpeed)
    else
        hrp.CFrame = targetCFrame
    end
end

-- === ОБНОВЛЕНИЕ ЦЕЛЕЙ ===
local function updateTargetList()
    if not Config.Enabled then return end
    
    State.targetList = {}
    local char = localPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local live = Workspace:FindFirstChild("Live")
    if not live then return end
    
    for _, obj in pairs(live:GetChildren()) do
        if obj ~= char and obj:IsA("Model") then
            local otherHrp = obj:FindFirstChild("HumanoidRootPart")
            local otherHum = obj:FindFirstChildOfClass("Humanoid")
            if otherHrp and otherHum and otherHum.Health > 0 then
                local dist = (hrp.Position - otherHrp.Position).Magnitude
                if dist < Config.TargetMaxDistance then
                    local player = Players:GetPlayerFromCharacter(obj)
                    local isWl = player and isWhitelisted(player)
                    local isTg = player and isTargeted(player)
                    
                    table.insert(State.targetList, {
                        Name = obj.Name,
                        Model = obj,
                        HRP = otherHrp,
                        Humanoid = otherHum,
                        Distance = dist,
                        Player = player,
                        IsWhitelisted = isWl,
                        IsTargeted = isTg,
                        Health = otherHum.Health,
                        MaxHealth = otherHum.MaxHealth,
                    })
                end
            end
        end
    end
    
    -- Сортировка
    if Config.TargetMode == "Nearest" then
        table.sort(State.targetList, function(a, b) return a.Distance < b.Distance end)
    elseif Config.TargetMode == "LowestHP" then
        table.sort(State.targetList, function(a, b) return (a.Health/a.MaxHealth) < (b.Health/b.MaxHealth) end)
    elseif Config.TargetMode == "Manual" then
        -- Ручной порядок
    end
    
    -- Приоритет для Targets
    table.sort(State.targetList, function(a, b)
        if a.IsTargeted and not b.IsTargeted then return true end
        if not a.IsTargeted and b.IsTargeted then return false end
        return false
    end)
    
    -- Автовыбор цели
    if Config.AutoTarget and not State.currentTarget and #State.targetList > 0 then
        State.currentTarget = State.targetList[1]
        State.selectedTargetIndex = 1
    end
    
    -- Обновление дистанции текущей цели
    if State.currentTarget and State.currentTarget.HRP then
        State.currentTarget.Distance = (hrp.Position - State.currentTarget.HRP.Position).Magnitude
        if State.currentTarget.Distance > Config.TargetMaxDistance then
            State.currentTarget = nil
        end
    end
end

-- === ESP СИСТЕМА ===
local function updateESP()
    if not Config.ESP or not Config.Enabled then
        for _, obj in pairs(State.espObjects) do
            if obj.Highlight then obj.Highlight:Destroy() end
            if obj.NameTag then obj.NameTag:Destroy() end
        end
        State.espObjects = {}
        return
    end
    
    local char = localPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Очистка старых
    for id, obj in pairs(State.espObjects) do
        local stillValid = false
        for _, target in pairs(State.targetList) do
            if target.Player and target.Player.UserId == id then
                stillValid = true
                break
            end
        end
        if not stillValid then
            if obj.Highlight then obj.Highlight:Destroy() end
            if obj.NameTag then obj.NameTag:Destroy() end
            State.espObjects[id] = nil
        end
    end
    
    -- Создание/обновление
    for _, target in pairs(State.targetList) do
        if not target.Player then continue end
        local id = target.Player.UserId
        local dist = target.Distance
        
        if dist > Config.ESPMaxDistance then continue end
        if not Config.ESPShowAll and target.IsWhitelisted then continue end
        
        local hasCounter = hasProjectileCounter(target)
        local isWl = target.IsWhitelisted
        local isTg = target.IsTargeted
        
        if not State.espObjects[id] then
            State.espObjects[id] = {}
        end
        local esp = State.espObjects[id]
        
        -- Highlight
        if not esp.Highlight or esp.Highlight.Parent ~= target.Model then
            if esp.Highlight then esp.Highlight:Destroy() end
            esp.Highlight = Instance.new("Highlight")
            esp.Highlight.Name = "LV_ESP"
            esp.Highlight.Parent = target.Model
        end
        
        -- Цвета
        if Config.ESPCounters and hasCounter then
            esp.Highlight.FillColor = Color3.fromRGB(255, 0, 0)
            esp.Highlight.OutlineColor = Color3.fromRGB(255, 50, 50)
            esp.Highlight.FillTransparency = 0.3
        elseif Config.ESPTargets and isTg then
            esp.Highlight.FillColor = Color3.fromRGB(100, 150, 255)
            esp.Highlight.OutlineColor = Color3.fromRGB(150, 200, 255)
            esp.Highlight.FillTransparency = 0.5
        elseif Config.ESPWhitelist and isWl then
            esp.Highlight.FillColor = Color3.fromRGB(255, 255, 255)
            esp.Highlight.OutlineColor = Color3.fromRGB(200, 200, 200)
            esp.Highlight.FillTransparency = 0.8
        else
            esp.Highlight.FillColor = Color3.fromRGB(100, 255, 100)
            esp.Highlight.OutlineColor = Color3.fromRGB(150, 255, 150)
            esp.Highlight.FillTransparency = 0.7
        end
        esp.Highlight.OutlineTransparency = 0
        esp.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        -- NameTag
        if Config.ESPNames then
            if not esp.NameTag or not esp.NameTag.Parent then
                if esp.NameTag then esp.NameTag:Destroy() end
                esp.NameTag = Instance.new("BillboardGui")
                esp.NameTag.Name = "LV_Name"
                esp.NameTag.Size = UDim2.new(0, 100, 0, 40)
                esp.NameTag.StudsOffset = Vector3.new(0, 3, 0)
                esp.NameTag.AlwaysOnTop = true
                esp.NameTag.Parent = target.Model:FindFirstChild("Head") or target.Model
                
                local label = Instance.new("TextLabel", esp.NameTag)
                label.Name = "MainLabel"
                label.Size = UDim2.new(1, 0, 0.5, 0)
                label.BackgroundTransparency = 1
                label.TextColor3 = Color3.fromRGB(255, 255, 255)
                label.TextStrokeTransparency = 0.5
                label.TextSize = 14
                label.Font = Enum.Font.GothamBold
                
                local distLabel = Instance.new("TextLabel", esp.NameTag)
                distLabel.Name = "DistLabel"
                distLabel.Size = UDim2.new(1, 0, 0.5, 0)
                distLabel.Position = UDim2.new(0, 0, 0.5, 0)
                distLabel.BackgroundTransparency = 1
                distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                distLabel.TextStrokeTransparency = 0.5
                distLabel.TextSize = 12
                distLabel.Font = Enum.Font.Gotham
            end
            
            local label = esp.NameTag:FindFirstChild("MainLabel")
            local distLabel = esp.NameTag:FindFirstChild("DistLabel")
            
            if label then
                local status = ""
                if hasCounter then status = " [COUNTER]" end
                if isTg then status = " [TARGET]" end
                if isWl then status = " [IGNORE]" end
                label.Text = target.Name .. status
            end
            if distLabel and Config.ESPDistance then
                distLabel.Text = string.format("%.1fm", dist)
            elseif distLabel then
                distLabel.Text = ""
            end
        end
    end
end

-- === ГЛАВНЫЙ КОМБАТ ЦИКЛ ===
local function combatLoop()
    if not Config.Enabled then
        if State.isBlocking then setBlock(false) end
        return
    end
    
    local now = tick()
    local char = localPlayer.Character
    if not char then return end
    
    -- Проверка статусов цели
    local hasDebrisNow = false
    local hasCounterNow = false
    local hasStunNow = false
    local hasFreezeNow = false
    local attacking = false
    
    if State.currentTarget then
        hasDebrisNow = hasSmallDebris(State.currentTarget)
        hasCounterNow = hasProjectileCounter(State.currentTarget)
        hasStunNow = hasComboStun(State.currentTarget)
        hasFreezeNow = hasFreeze(State.currentTarget)
        attacking = isEnemyAttacking(State.currentTarget)
    end
    
    -- Сброс флагов
    if not hasDebrisNow then State.clickedAfterDebris = false end
    if not hasStunNow then State.clickedAfterStun = false end
    if not hasFreezeNow then State.clickedAfterFreeze = false end
    if not hasCounterNow and now > State.projectileProtectionEndTime then State.clickedAfterCounter = false end
    
    -- Защита от Counter
    if hasCounterNow and Config.BlockCounter then
        State.projectileProtectionEndTime = now + COMBAT.PROTECTION_WINDOW
    end
    
    -- Отпускание блока когда Debris пропал
    if State.hadDebrisLastFrame and not hasDebrisNow then
        if State.isBlocking and Config.Block then
            setBlock(false)
        end
        State.smallDebrisEndTime = now
    end
    
    State.hadDebrisLastFrame = hasDebrisNow
    
    -- Поворот к цели
    rotateToTarget()
    
    -- Обновление ESP
    updateESP()
    
    -- Обновление целей каждые 0.3 сек
    if now % 0.3 < 0.02 then
        updateTargetList()
    end
    
    if not State.currentTarget then
        if State.isBlocking then setBlock(false) end
        State.wasAttacking = false
        return
    end
    
    local timeSinceDebris = now - State.smallDebrisEndTime
    
    -- === ПРИОРИТЕТ 0: ЗАЩИТА ОТ COUNTER ===
    if now < State.projectileProtectionEndTime and Config.BlockCounter then
        if attacking and not State.isBlocking then
            setBlock(true)
        elseif not attacking and State.isBlocking then
            setBlock(false)
        end
        return
    end
    
    -- === ПРИОРИТЕТ 1: SMALL DEBRIS ===
    if hasDebrisNow and Config.BlockDebris then
        if not State.isBlocking then
            setBlock(true)
        end
        if Config.AttackOnDebris and not State.clickedAfterDebris and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterDebris = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 2: 0.5С ПОСЛЕ DEBRIS ===
    if timeSinceDebris < COMBAT.ATTACK_WINDOW and timeSinceDebris > 0 then
        if Config.AttackOnDebris and not State.clickedAfterDebris and not attacking and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterDebris = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 3: COMBOSTUN ===
    if hasStunNow and Config.AttackOnStun then
        if not State.clickedAfterStun and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterStun = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 4: FREEZE ===
    if hasFreezeNow and not attacking and Config.AttackOnFreeze then
        if not State.clickedAfterFreeze and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
            if doInstantClick() then
                State.clickedAfterFreeze = true
            end
        end
        return
    end
    
    -- === ПРИОРИТЕТ 5: ОБЫЧНАЯ ЛОГИКА (БЛОК → КЛИК) ===
    if Config.BlockM1 then
        if attacking and not State.wasAttacking then
            State.wasAttacking = true
            setBlock(true)
        end
        
        if not attacking and State.wasAttacking then
            State.wasAttacking = false
            setBlock(false)
            
            if Config.AttackAfterBlock and State.currentTarget.Distance <= COMBAT.ATTACK_RANGE then
                doInstantClick()
            end
        end
    end
end

