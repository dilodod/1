function Window:CreateToggle(tab, text, configKey)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -100, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    -- Toggle bg
    local bg = Instance.new("Frame")
    bg.Name = "ToggleBg"
    bg.Size = UDim2.new(0, 50, 0, 26)
    bg.Position = UDim2.new(1, -58, 0.5, -13)
    bg.BackgroundColor3 = (self.Config[configKey]) and self.Theme.ToggleOn or self.Theme.ToggleOff
    bg.BorderSizePixel = 0
    bg.Parent = frame
    CreateCorner(bg, 13)
    CreateStroke(bg, self.Theme.Border, 1)
    
    -- Knob
    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 22, 0, 22)
    knob.Position = (self.Config[configKey]) and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = bg
    CreateCorner(knob, 11)
    
    self.ToggleRefs[configKey] = {bg = bg, knob = knob, frame = frame}
    
    local callback = nil
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            self.Config[configKey] = not self.Config[configKey]
            local newState = self.Config[configKey]
            
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = newState and self.Theme.ToggleOn or self.Theme.ToggleOff}):Play()
            TweenService:Create(knob, TweenInfo.new(0.2), {Position = newState and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)}):Play()
            
            if callback then callback(newState) end
        end
    end)
    
    return {
        SetCallback = function(fn) callback = fn; return self end,
        SetValue = function(value)
            self.Config[configKey] = value
            bg.BackgroundColor3 = value and self.Theme.ToggleOn or self.Theme.ToggleOff
            knob.Position = value and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)
        end
    }
end

function Window:CreateInput(tab, text, configKey, isNumber, min, max)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 80, 0, 28)
    input.Position = UDim2.new(1, -88, 0.5, -14)
    input.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    input.Text = tostring(self.Config[configKey] or "")
    input.TextColor3 = self.Theme.Text
    input.TextSize = 13
    input.Font = Enum.Font.Gotham
    input.ClearTextOnFocus = false
    input.Parent = frame
    CreateCorner(input, 6)
    CreateStroke(input, self.Theme.Border, 1)
    
    local callback = nil
    
    input.FocusLost:Connect(function()
        local value = input.Text
        if isNumber then
            local num = tonumber(value)
            if num then
                if min and num < min then num = min end
                if max and num > max then num = max end
                self.Config[configKey] = num
                input.Text = tostring(num)
            else
                input.Text = tostring(self.Config[configKey] or "")
            end
        else
            self.Config[configKey] = value
        end
        if callback then callback(self.Config[configKey]) end
    end)
    
    return {
        SetCallback = function(fn) callback = fn; return self end,
        SetText = function(text) input.Text = tostring(text) end
    }
end

function Window:CreateDropdown(tab, text, configKey, options)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.4, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 130, 0, 28)
    btn.Position = UDim2.new(1, -138, 0.5, -14)
    btn.BackgroundColor3 = self.Theme.TabInactive
    btn.Text = tostring(self.Config[configKey] or options[1] or "Select")
    btn.TextColor3 = self.Theme.Text
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.Parent = frame
    CreateCorner(btn, 6)
    CreateStroke(btn, self.Theme.Border, 1)
    
    local callback = nil
    
    btn.MouseButton1Click:Connect(function()
        local current = self.Config[configKey]
        local index = 1
        for i, v in ipairs(options) do
            if v == current then index = i; break end
        end
        local nextIndex = (index % #options) + 1
        self.Config[configKey] = options[nextIndex]
        btn.Text = options[nextIndex]
        if callback then callback(options[nextIndex]) end
    end)
    
    return {SetCallback = function(fn) callback = fn; return self end}
end

