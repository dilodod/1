-- LocalScript, поместить в StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local PathfindingService = game:GetService("PathfindingService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Настройки
local HIGHLIGHT_COLOR_BENCH = Color3.fromRGB(0, 255, 0)
local HIGHLIGHT_COLOR_TRASH = Color3.fromRGB(255, 0, 0)
local MAX_DISTANCE = 500
local WALK_SPEED = 32
local PROXIMITY_DISTANCE = 3.5 -- Дистанция "в притык"
local FLY_UP_HEIGHT = 50
local FLY_SIDE_DISTANCE = 14

-- Анимации
local ANIM_ID_1 = "rbxassetid://180436334"
local ANIM_ID_2 = "rbxassetid://10480793962"

-- Состояния
local highlights = {}
local currentPath = nil
local isRunning = false
local isAnimating = false

-- Установка скорости
humanoid.WalkSpeed = WALK_SPEED

-- Проверка видимости
local function isVisible(obj)
    local part = getPart(obj)
    if not part then return false end
    return part.Transparency < 1 and part.Parent ~= nil
end

-- Получение части
function getPart(obj)
    if obj:IsA("BasePart") then
        return obj
    elseif obj:IsA("Model") then
        return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    end
    return nil
end

-- Получение позиции
local function getPosition(obj)
    local part = getPart(obj)
    return part and part.Position or nil
end

-- Создание подсветки
local function createHighlight(obj, color)
    local part = getPart(obj)
    if not part or highlights[part] or not isVisible(obj) then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = part
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = part
    highlights[part] = highlight
end

-- Подсветка всех объектов
local function setupHighlights()
    for part, hl in pairs(highlights) do
        hl:Destroy()
    end
    highlights = {}
    
    local benchsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Benchs")
    local trashFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Trash")
    
    if benchsFolder then
        for _, obj in ipairs(benchsFolder:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("Model")) and isVisible(obj) then
                createHighlight(obj, HIGHLIGHT_COLOR_BENCH)
            end
        end
    end
    
    if trashFolder then
        for _, obj in ipairs(trashFolder:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("Model")) and isVisible(obj) then
                createHighlight(obj, HIGHLIGHT_COLOR_TRASH)
            end
        end
    end
end

-- Поиск ближайшего видимого объекта
local function findNearestObject()
    local nearest = nil
    local nearestDist = math.huge
    
    local benchsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Benchs")
    local trashFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Trash")
    
    local function checkFolder(folder)
        if not folder then return end
        for _, obj in ipairs(folder:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("Model")) and isVisible(obj) then
                local pos = getPosition(obj)
                if pos then
                    local dist = (humanoidRootPart.Position - pos).Magnitude
                    if dist < nearestDist and dist <= MAX_DISTANCE then
                        nearestDist = dist
                        nearest = obj
                    end
                end
            end
        end
    end
    
    checkFolder(benchsFolder)
    checkFolder(trashFolder)
    
    return nearest
end

-- Остановка движения
local function stopMoving()
    isRunning = false
    currentPath = nil
    humanoid:MoveTo(humanoidRootPart.Position)
end

-- Основная анимационная последовательность "в притык"
local function playProximitySequence(targetObj)
    if isAnimating then return end
    isAnimating = true
    isRunning = false
    
    local targetPart = getPart(targetObj)
    if not targetPart then 
        isAnimating = false
        return 
    end
    
    -- Отключаем физику персонажа на время анимации
    humanoid.PlatformStand = true
    
    -- 1. ПРИЖИМАЕМСЯ К ПАРТУ (0.2 сек)
    local targetCFrame = targetPart.CFrame * CFrame.new(0, 0, -2) -- Спереди на 2 студа
    local tween1 = TweenService:Create(
        humanoidRootPart,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {CFrame = targetCFrame}
    )
    tween1:Play()
    tween1.Completed:Wait()
    
    -- 2. ЗАКРЕПЛЯЕМСЯ (0.1 сек подъём на 2 студа)
    local attachCFrame = humanoidRootPart.CFrame * CFrame.new(0, 2, 0)
    local tween2 = TweenService:Create(
        humanoidRootPart,
        TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {CFrame = attachCFrame}
    )
    tween2:Play()
    tween2.Completed:Wait()
    
    -- 3. ПРОИГРЫВАЕМ АНИМАЦИЮ 180436334 (0.3 сек)
    local anim1 = Instance.new("Animation")
    anim1.AnimationId = ANIM_ID_1
    local track1 = humanoid:LoadAnimation(anim1)
    track1:Play()
    track1:AdjustSpeed(3.33) -- 0.3 сек = 3.33x скорость (стандарт 1 сек)
    
    task.wait(0.3)
    track1:AdjustSpeed(0) -- Останавливаем, поза застывает
    
    -- 4. ЖДЁМ 0.5 сек
    task.wait(0.5)
    
    -- 5. АКТИВИРУЕМ REMOTEEVENT
    local communicate = character:FindFirstChild("Communicate")
    if communicate and communicate:IsA("RemoteEvent") then
        communicate:FireServer()
    end
    
    -- 6. НАЧИНАЕМ ПОДЛЁТ (0.1 сек задержка + подлёт 0.3 сек)
    -- Сначала включаем PlatformStand для физики полёта
    humanoid.PlatformStand = true
    
    -- Создаём BodyVelocity для контроля полёта
    local bodyVel = Instance.new("BodyVelocity")
    bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVel.Velocity = Vector3.zero
    bodyVel.Parent = humanoidRootPart
    
    local bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.CFrame = humanoidRootPart.CFrame
    bodyGyro.Parent = humanoidRootPart
    
    -- Подлёт вверх на 50 стадов + вбок на 14 стадов
    local flyGoal = humanoidRootPart.CFrame * CFrame.new(FLY_SIDE_DISTANCE, FLY_UP_HEIGHT, 0)
    
    task.wait(0.1) -- Задержка 0.1 перед подлётом
    
    local tween3 = TweenService:Create(
        humanoidRootPart,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {CFrame = flyGoal}
    )
    tween3:Play()
    
    -- 7. ВО ВРЕМЯ ПОДЛЁТА — АНИМАЦИЯ 10480793962
    local anim2 = Instance.new("Animation")
    anim2.AnimationId = ANIM_ID_2
    local track2 = humanoid:LoadAnimation(anim2)
    track2:Play()
    
    tween3.Completed:Wait()
    
    -- Чистим
    bodyVel:Destroy()
    bodyGyro:Destroy()
    humanoid.PlatformStand = false
    isAnimating = false
end

-- Движение к объекту
local function moveToObject(targetObj)
    if not targetObj or isRunning or isAnimating then return end
    
    if not isVisible(targetObj) then
        isRunning = false
        return
    end
    
    isRunning = true
    
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentJumpHeight = 7,
        AgentMaxSlope = 45
    })
    
    currentPath = path
    
    local targetPos = getPosition(targetObj)
    if not targetPos then 
        isRunning = false 
        return 
    end
    
    local success = pcall(function()
        path:ComputeAsync(humanoidRootPart.Position, targetPos)
    end)
    
    if success and path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        
        for i, waypoint in ipairs(waypoints) do
            if not isRunning or isAnimating then break end
            
            if not isVisible(targetObj) then
                stopMoving()
                return
            end
            
            -- Проверяем дистанцию до цели
            local currentDist = (humanoidRootPart.Position - targetPos).Magnitude
            if currentDist <= PROXIMITY_DISTANCE then
                stopMoving()
                playProximitySequence(targetObj)
                return
            end
            
            humanoid:MoveTo(waypoint.Position)
            
            local reached = false
            local connection
            connection = humanoid.MoveToFinished:Connect(function()
                reached = true
                if connection then connection:Disconnect() end
            end)
            
            local startTime = tick()
            while not reached and isRunning and not isAnimating do
                -- Проверяем дистанцию во время движения
                local dist = (humanoidRootPart.Position - targetPos).Magnitude
                if dist <= PROXIMITY_DISTANCE then
                    if connection then connection:Disconnect() end
                    stopMoving()
                    playProximitySequence(targetObj)
                    return
                end
                
                if tick() - startTime > 5 then
                    break
                end
                task.wait(0.05)
            end
            
            if connection then connection:Disconnect() end
            
            if waypoint.Action == Enum.PathWaypointAction.Jump then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        
        -- После всех waypoints проверяем ещё раз дистанцию
        local finalDist = (humanoidRootPart.Position - targetPos).Magnitude
        if finalDist <= PROXIMITY_DISTANCE then
            stopMoving()
            playProximitySequence(targetObj)
            return
        end
        
    else
        humanoid:MoveTo(targetPos)
        -- Ждём приближения
        while isRunning and not isAnimating do
            local dist = (humanoidRootPart.Position - targetPos).Magnitude
            if dist <= PROXIMITY_DISTANCE then
                stopMoving()
                playProximitySequence(targetObj)
                return
            end
            if not isVisible(targetObj) then
                stopMoving()
                return
            end
            task.wait(0.05)
        end
    end
    
    isRunning = false
    currentPath = nil
end

-- Создание GUI кнопки
local function createButton()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AutoMoveGui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = player:WaitForChild("PlayerGui")
    
    local button = Instance.new("TextButton")
    button.Name = "MoveButton"
    button.Size = UDim2.new(0, 120, 0, 50)
    button.Position = UDim2.new(0.5, -60, 0.9, -25)
    button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Text = "Бежать"
    button.TextSize = 20
    button.Font = Enum.Font.SourceSansBold
    button.BorderSizePixel = 2
    button.BorderColor3 = Color3.fromRGB(0, 0, 0)
    button.Parent = screenGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = button
    
    button.MouseButton1Click:Connect(function()
        if isAnimating then return end
        
        if isRunning then
            stopMoving()
            button.Text = "Бежать"
            button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        else
            local nearest = findNearestObject()
            if nearest then
                button.Text = "Стоп"
                button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                moveToObject(nearest)
            else
                button.Text = "Нет цели"
                task.wait(1)
                button.Text = "Бежать"
            end
        end
    end)
    
    RunService.Heartbeat:Connect(function()
        if not isRunning and not isAnimating and button.Text == "Стоп" then
            button.Text = "Бежать"
            button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        end
    end)
    
    return button
end

-- Респавн
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    humanoidRootPart = newChar:WaitForChild("HumanoidRootPart")
    humanoid.WalkSpeed = WALK_SPEED
    isRunning = false
    isAnimating = false
    setupHighlights()
end)

-- Инициализация
setupHighlights()

-- Обновление подсветки
local mapFolder = workspace:FindFirstChild("Map")
if mapFolder then
