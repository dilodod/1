function Window:CreateToggle(tab, text, configKey, default)
    default = default or false
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 44)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -100, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    -- Toggle
    local bg = Instance.new("Frame")
    bg.Name = "ToggleBg"
    bg.Size = UDim2.new(0, 54, 0, 28)
    bg.Position = UDim2.new(1, -62, 0.5, -14)
    bg.BackgroundColor3 = self.Theme.ToggleOff
    bg.BorderSizePixel = 0
    bg.Parent = frame
    CreateCorner(bg, 14)
    CreateStroke(bg, self.Theme.Border, 1)
    
    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 24, 0, 24)
    knob.Position = UDim2.new(0, 2, 0.5, -12)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = bg
    CreateCorner(knob, 12)
    CreateStroke(knob, self.Theme.Border, 1)
    
    -- Сохраняем ссылку
    if not self.Elements[configKey] then self.Elements[configKey] = {} end
    table.insert(self.Elements[configKey], {type = "toggle", bg = bg, knob = knob})
    
    -- Устанавливаем значение
    local value = self.Config:Get(configKey, default)
    local function updateVisual(state)
        bg.BackgroundColor3 = state and self.Theme.ToggleOn or self.Theme.ToggleOff
        knob.Position = state and UDim2.new(1, -26, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
    end
    updateVisual(value)
    
    local callback = nil
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local newState = not self.Config:Get(configKey)
            self.Config:Set(configKey, newState)
            
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = newState and self.Theme.ToggleOn or self.Theme.ToggleOff}):Play()
            TweenService:Create(knob, TweenInfo.new(0.2), {
                Position = newState and UDim2.new(1, -26, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
            }):Play()
            
            if callback then callback(newState) end
        end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetValue = function(val)
            self.Config:Set(configKey, val)
            updateVisual(val)
        end,
        GetValue = function() return self.Config:Get(configKey) end
    }
end

function Window:CreateSlider(tab, text, configKey, min, max, decimals)
    min, max = min or 0, max or 100
    decimals = decimals or 0
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 60)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 0, 24)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(self.Config:Get(configKey, min))
    label.TextColor3 = self.Theme.Text
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    -- Slider
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 12)
    sliderBg.Position = UDim2.new(0, 10, 0, 38)
    sliderBg.BackgroundColor3 = Color3.fromRGB(220, 210, 150)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = frame
    CreateCorner(sliderBg, 6)
    
    local sliderFill = Instance.new("Frame")
    sliderFill.BackgroundColor3 = self.Theme.ToggleOn
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg
    CreateCorner(sliderFill, 6)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = sliderBg
    CreateCorner(knob, 9)
    CreateStroke(knob, self.Theme.Border, 1)
    
    -- Сохраняем ссылку
    if not self.Elements[configKey] then self.Elements[configKey] = {} end
    table.insert(self.Elements[configKey], {type = "slider", label = label, fill = sliderFill, knob = knob, min = min, max = max})
    
    local function updateVisual(value)
        local percent = math.clamp((value - min) / (max - min), 0, 1)
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -9, 0.5, -9)
        label.Text = text .. ": " .. tostring(value)
    end
    
    updateVisual(self.Config:Get(configKey, min))
    
    local dragging = false
    local callback = nil
    
    local function updateFromInput(input)
        local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        local value = min + (max - min) * pos
        if decimals > 0 then
            value = math.floor(value * (10 ^ decimals)) / (10 ^ decimals)
        else
            value = math.floor(value)
        end
        
        self.Config:Set(configKey, value)
        updateVisual(value)
        if callback then callback(value) end
    end
    
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromInput(input)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromInput(input)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetValue = function(val)
            self.Config:Set(configKey, math.clamp(val, min, max))
            updateVisual(val)
        end,
        GetValue = function() return self.Config:Get(configKey) end
    }
end

function Window:CreateInput(tab, text, configKey, isNumber, min, max)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 44)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.Theme.Text
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 100, 0, 32)
    input.Position = UDim2.new(1, -108, 0.5, -16)
    input.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    input.Text = tostring(self.Config:Get(configKey, ""))
    input.PlaceholderText = "..."
    input.TextColor3 = self.Theme.Text
    input.TextSize = 13
    input.Font = Enum.Font.Gotham
    input.ClearTextOnFocus = false
    input.Parent = frame
    CreateCorner(input, 6)
    CreateStroke(input, self.Theme.Border, 1)
    
    local callback = nil
    
    input.FocusLost:Connect(function()
        local value = input.Text
        if isNumber then
            local num = tonumber(value)
            if num then
                if min then num = math.max(num, min) end
                if max then num = math.min(num, max) end
                self.Config:Set(configKey, num)
                input.Text = tostring(num)
            else
                input.Text = tostring(self.Config:Get(configKey, ""))
            end
        else
            self.Config:Set(configKey, value)
        end
        if callback then callback(self.Config:Get(configKey)) end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetText = function(text) input.Text = tostring(text) end,
        GetValue = function() return self.Config:Get(configKey) end
    }
end

function Window:CreateDropdown(tab, text, configKey, options)
