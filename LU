function Window:CreateSlider(tab, text, configKey, min, max, decimals)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 0, 20)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(self.Config[configKey] or min)
    label.TextColor3 = self.Theme.Text
    label.TextSize = 12
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    -- Slider bg
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 10)
    sliderBg.Position = UDim2.new(0, 10, 0, 30)
    sliderBg.BackgroundColor3 = Color3.fromRGB(220, 210, 150)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = frame
    CreateCorner(sliderBg, 5)
    
    -- Slider fill
    local sliderFill = Instance.new("Frame")
    local percent = math.clamp((self.Config[configKey] or min - min) / (max - min), 0, 1)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderFill.BackgroundColor3 = self.Theme.ToggleOn
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg
    CreateCorner(sliderFill, 5)
    
    -- Slider knob
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(percent, -8, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = sliderBg
    CreateCorner(knob, 8)
    CreateStroke(knob, self.Theme.Border, 1)
    
    local dragging = false
    local callback = nil
    
    local function updateSlider(input)
        local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        local value = min + (max - min) * pos
        if decimals then
            value = math.floor(value * (10 ^ decimals)) / (10 ^ decimals)
        else
            value = math.floor(value)
        end
        
        self.Config[configKey] = value
        label.Text = text .. ": " .. tostring(value)
        sliderFill.Size = UDim2.new(pos, 0, 1, 0)
        knob.Position = UDim2.new(pos, -8, 0.5, -8)
        
        if callback then callback(value) end
    end
    
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input)
        end
    end)
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return {SetCallback = function(fn) callback = fn; return self end}
end

-- === КОНФИГИ ===

function Window:SaveConfig(name)
    local data = {}
    for k, v in pairs(self.Config) do
        data[k] = v
    end
    data._version = "2.1"
    
    local json = HttpService:JSONEncode(data)
    local success = pcall(function()
        writefile("YellowUI_" .. name .. ".json", json)
    end)
    return success
end

function Window:LoadConfig(name)
    local success, result = pcall(function()
        return readfile("YellowUI_" .. name .. ".json")
    end)
    
    if success and result then
        local data = HttpService:JSONDecode(result)
        for k, v in pairs(data) do
            self.Config[k] = v
        end
        
        -- Обновляем тогглы
        for key, refs in pairs(self.ToggleRefs) do
            if self.Config[key] ~= nil then
                local state = self.Config[key]
                refs.bg.BackgroundColor3 = state and self.Theme.ToggleOn or self.Theme.ToggleOff
                refs.knob.Position = state and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)
            end
        end
        
        -- Восстанавливаем вкладки
        if data._savedTabs then
            self:RestoreSavedTabs()
        end
        
        return true
    end
    return false
end

