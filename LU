    knob.Position = UDim2.new(0, 2, 0.5, -12)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = bg
    CreateCorner(knob, 12)
    CreateStroke(knob, self.Theme.Border, 1)
    
    if not self.Elements[key] then self.Elements[key] = {} end
    table.insert(self.Elements[key], {type = "toggle", bg = bg, knob = knob})
    
    local value = self.Config:Get(key, default)
    local function update(state)
        bg.BackgroundColor3 = state and self.Theme.ToggleOn or self.Theme.ToggleOff
        knob.Position = state and UDim2.new(1, -26, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
    end
    update(value)
    
    local callback = nil
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local newState = not self.Config:Get(key)
            self.Config:Set(key, newState)
            update(newState)
            if callback then callback(newState) end
        end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetValue = function(val) self.Config:Set(key, val); update(val) end,
        GetValue = function() return self.Config:Get(key) end
    }
end

function Window:CreateSlider(tab, text, key, min, max, decimals)
    min, max = min or 0, max or 100
    decimals = decimals or 0
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 60)
    frame.BackgroundColor3 = self.Theme.ItemBg
    frame.Parent = tab.Content
    CreateCorner(frame, 8)
    CreateStroke(frame, self.Theme.Border, 1)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 0, 24)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(self.Config:Get(key, min))
    label.TextColor3 = self.Theme.Text
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 12)
    sliderBg.Position = UDim2.new(0, 10, 0, 38)
    sliderBg.BackgroundColor3 = Color3.fromRGB(220, 210, 150)
    sliderBg.Parent = frame
    CreateCorner(sliderBg, 6)
    
    local fill = Instance.new("Frame")
    fill.BackgroundColor3 = self.Theme.ToggleOn
    fill.Parent = sliderBg
    CreateCorner(fill, 6)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = sliderBg
    CreateCorner(knob, 9)
    CreateStroke(knob, self.Theme.Border, 1)
    
    if not self.Elements[key] then self.Elements[key] = {} end
    table.insert(self.Elements[key], {type = "slider", label = label, fill = fill, knob = knob, min = min, max = max})
    
    local function updateVisual(val)
        local pct = math.clamp((val - min) / (max - min), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, -9, 0.5, -9)
        label.Text = text .. ": " .. tostring(val)
    end
    
    updateVisual(self.Config:Get(key, min))
    
    local dragging = false
    local callback = nil
    
    local function update(input)
        local pct = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * pct
        if decimals > 0 then
            val = math.floor(val * (10 ^ decimals)) / (10 ^ decimals)
        else
            val = math.floor(val)
        end
        self.Config:Set(key, val)
        updateVisual(val)
        if callback then callback(val) end
    end
    
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return {
        SetCallback = function(fn) callback = fn end,
        SetValue = function(val) self.Config:Set(key, math.clamp(val, min, max)); updateVisual(val) end,
        GetValue = function() return self.Config:Get(key) end
    }
end

