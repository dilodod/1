-- === ЛОГИКА БОЯ (из 3го скрипта) ===
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

-- Константы
local CHECK_RADIUS = 12
local ATTACK_RANGE = 9
local COMBO_STUN = "combostun"
local FREEZE = "Freeze"
local SMALL_DEBRIS = "Small Debris"
local RAGDOLL = "Ragdoll"
local PROJECTILE_COUNTER = "ProjectileCounter"
local ATOMIC_COUNTER = "AtomicCounter"

-- Состояния
local isBlocking = false
local lastAttackTime = 0
local wasAttacking = false
local freezeActive = false
local ragdollActive = false
local smallDebrisEndTime = 0
local hadDebrisLastFrame = false
local projectileProtectionEndTime = 0

-- Флаги кликов
local clickedAfterDebris = false
local clickedAfterStun = false
local clickedAfterFreeze = false
local clickedAfterCounter = false

local currentTarget = nil
local lockedTarget = nil

-- Проверки статусов
local function hasComboStun(target)
    return target and target.Character and target.Character:FindFirstChild(COMBO_STUN) ~= nil
end

local function hasSmallDebris(target)
    return target and target.Character and target.Character:FindFirstChild(SMALL_DEBRIS) ~= nil
end

local function hasFreeze(target)
    return target and target.Character and target.Character:FindFirstChild(FREEZE) ~= nil
end

local function hasProjectileCounter(target)
    return target and target.Character and (target.Character:FindFirstChild(PROJECTILE_COUNTER) ~= nil or target.Character:FindFirstChild(ATOMIC_COUNTER) ~= nil)
end

local function hasOurRagdoll()
    return ragdollActive or character:FindFirstChild(RAGDOLL) ~= nil
end

-- Получение цели
local function getTarget()
    -- Приоритет 1: Зафиксированная цель
    if lockedTarget and lockedTarget.Character and lockedTarget.Character:FindFirstChild("HumanoidRootPart") then
        if not Config.Whitelist[lockedTarget.UserId] then
            return lockedTarget
        end
    end
    
    -- Приоритет 2: Выбранные цели
    for uid, _ in pairs(Config.Targets) do
        local pl = Players:GetPlayerByUserId(uid)
        if pl and pl ~= player and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
            if not Config.Whitelist[pl.UserId] then
                return pl
            end
        end
    end
    
    -- Приоритет 3: Ближайший по режиму
    local nearest = nil
    local minDist = Config.TargetMaxDistance
    
    for _, pl in pairs(Players:GetPlayers()) do
        if pl ~= player and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
            if not Config.Whitelist[pl.UserId] then
                local dist = (pl.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = pl
                end
            end
        end
    end
    
    return nearest
end

-- Наводка
local function aimAt(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    if hasOurRagdoll() then return end
    
    local targetHRP = target.Character.HumanoidRootPart
    local targetPos = targetHRP.Position
    local myPos = hrp.Position
    
    -- Расчёт скорости
    local hasDebris = hasSmallDebris(target)
    local speed = (hasDebris and Config.AimFastOnDebris) and Config.AimFastSpeed or Config.AimSpeed
    
    -- Плавная наводка
    local dir = Vector3.new(targetPos.X - myPos.X, 0, targetPos.Z - myPos.Z).Unit
    if Config.AimY then
        dir = (targetPos - myPos).Unit
    end
    
    local targetCFrame = CFrame.new(myPos, myPos + dir)
    hrp.CFrame = hrp.CFrame:Lerp(targetCFrame, speed)
end

-- Действия
local function sendAction(action, key)
    if not character:FindFirstChild("Communicate") then return end
    pcall(function()
        character.Communicate:FireServer({
            ["Goal"] = action,
            ["Key"] = key,
            ["Mobile"] = true
        })
    end)
end

local function setBlock(pressed)
    if pressed == isBlocking then return end
    sendAction(pressed and "KeyPress" or "KeyRelease", Enum.KeyCode.F)
    isBlocking = pressed
end

-- Клик (мгновенный или обычный)
local function doClick()
    if tick() - lastAttackTime < Config.AttackDelay then return false end
    if not currentTarget or not currentTarget.Character then return false end
    
    local targetHRP = currentTarget.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return false end
    
    local dist = (targetHRP.Position - hrp.Position).Magnitude
    if dist > ATTACK_RANGE then return false end
    
    lastAttackTime = tick()
    
    if Config.InstantClick then
        -- Мгновенный клик
        sendAction("LeftClick", Enum.UserInputType.MouseButton1)
        sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
    else
        -- Обычный клик с задержкой
        sendAction("LeftClick", Enum.UserInputType.MouseButton1)
        task.delay(Config.ClickDuration, function()
            sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
        end)
    end
    
    -- Black Flash
    if Config.BlackFlash and math.random(1, 100) <= Config.BFChance then
        task.delay(Config.BFDuration, function()
            sendAction("LeftClick", Enum.UserInputType.MouseButton1)
            sendAction("LeftClickRelease", Enum.UserInputType.MouseButton1)
        end)
    end
    
    return true
end

-- Проверка атаки врага
local function isEnemyAttacking(target)
    if not target or not target.Character then return false end
    local char = target.Character
    
    if char:FindFirstChild("M1ing") then return true end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            local name = track.Name:lower()
            if (name:find("punch") or name:find("attack") or name:find("m1") or name:find("swing")) and track.IsPlaying then
                return true
            end
        end
    end
    return false
end

-- Главный цикл боя
local lastTick = 0
local ATTACK_WINDOW = 0.5
local PROTECTION_WINDOW = 0.3
local FAST_ROTATION_SPEED = 0.02
local TICK_RATE = 0.008

RunService.Heartbeat:Connect(function()
    local now = tick()
    
    -- Обновление цели
    if Config.Aim or Config.Attack or Config.Block then
        currentTarget = getTarget()
    end
    
    -- Наводка
    if Config.Aim and currentTarget then
        aimAt(currentTarget)
    end
    
    -- Логика блока/атаки
    if not Config.Block and not Config.Attack then return end
    
    local hasDebrisNow = false
    local hasCounterNow = false
    local hasStunNow = false
    local hasFreezeNow = false
    
    if currentTarget then
        hasDebrisNow = hasSmallDebris(currentTarget)
        hasCounterNow = hasProjectileCounter(currentTarget)
        hasStunNow = hasComboStun(currentTarget)
        hasFreezeNow = hasFreeze(currentTarget)
    end
    
    -- Сброс флагов
    if not hasDebrisNow then clickedAfterDebris = false end
    if not hasStunNow then clickedAfterStun = false end
    if not hasFreezeNow then clickedAfterFreeze = false end
    if not hasCounterNow and now > projectileProtectionEndTime then clickedAfterCounter = false end
    
    -- Каунтер запускает защиту
    if hasCounterNow and Config.BlockCounter then
        projectileProtectionEndTime = now + PROTECTION_WINDOW
    end
    
    local currentTickRate = (hasDebrisNow and Config.AimFastOnDebris) and FAST_ROTATION_SPEED or TICK_RATE
    if now - lastTick < currentTickRate then return end
    lastTick = now
    
    -- Отпускаем блок когда Debris пропал
    if hadDebrisLastFrame and not hasDebrisNow then
        if isBlocking then setBlock(false) end
        smallDebrisEndTime = now
    end
    hadDebrisLastFrame = hasDebrisNow
    
    if not currentTarget then
        if isBlocking then setBlock(false) end
        wasAttacking = false
        return
    end
    
    local attacking = isEnemyAttacking(currentTarget)
    local timeSinceDebris = now - smallDebrisEndTime
    
    -- === УМНЫЙ БЛОК С ПРИОРИТЕТАМИ ===
    if Config.SmartBlock then
        -- Приоритет 0: Каунтер
        if now < projectileProtectionEndTime and Config.BlockCounter then
            if attacking and not isBlocking then
                setBlock(true)
            elseif not attacking and isBlocking then
                setBlock(false)
            end
            return
        end
        
        -- Приоритет 1: Обломки
        if hasDebrisNow and Config.BlockDebris then
            if not isBlocking then setBlock(true) end
            if Config.AttackOnDebris and not clickedAfterDebris then
                if doClick() then clickedAfterDebris = true end
            end
            return
        end
        
        -- Приоритет 2: После обломков (0.5с)
        if timeSinceDebris < ATTACK_WINDOW and timeSinceDebris > 0 then
            if not clickedAfterDebris and not attacking and Config.Attack then
                if doClick() then clickedAfterDebris = true end
            end
            return
        end
        
        -- Приоритет 3: Стан
        if hasStunNow and Config.AttackOnStun then
            if not clickedAfterStun then
                if doClick() then clickedAfterStun = true end
            end
            return
        end
        
        -- Приоритет 4: Заморозка
        if hasFreezeNow and not attacking and Config.AttackOnFreeze then
            if not clickedAfterFreeze then
                if doClick() then clickedAfterFreeze = true end
            end
            return
        end
    end
    
    -- === ОБЫЧНЫЙ БЛОК/АТАКА ===
    if Config.Block then
        if Config.BlockM1 and attacking and not wasAttacking then
            wasAttacking = true
            setBlock(true)
        end
        
        if not attacking and wasAttacking then
            wasAttacking = false
            setBlock(false)
            if Config.Attack then doClick() end
        end
    end
    
    -- Просто атака
    if Config.Attack and not Config.Block then
        doClick()
    end
end)

-- === ESP СИСТЕМА ===
local espBoxes = {}
local espNames = {}
local espDistances = {}

local function createESP(pl)
    if pl == player then return end
    
    local box = Drawing.new("Square")
    box.Visible = false
    box.Thickness = 1.5
    box.Transparency = 1
    box.Filled = false
    
    local name = Drawing.new("Text")
    name.Visible = false
    name.Size = 13
    name.Center = true
    name.Outline = true
    
    local dist = Drawing.new("Text")
    dist.Visible = false
    dist.Size = 11
    dist.Center = true
    dist.Outline = true
    
    espBoxes[pl] = box
    espNames[pl] = name
    espDistances[pl] = dist
end

local function updateESP()
    for pl, box in pairs(espBoxes) do
        local name = espNames[pl]
        local dist = espDistances[pl]
        
        if not pl or not pl.Parent then
            box.Visible = false
            name.Visible = false
            dist.Visible = false
            continue
        end
        
        local isWhitelisted = Config.Whitelist[pl.UserId] == true
        local isTargeted = Config.Targets[pl.UserId] == true
        
        local shouldShow = false
        if Config.ESPShowAll then
            shouldShow = true
        else
            if isWhitelisted and Config.ESPWhitelist then shouldShow = true end
            if isTargeted and Config.ESPTargets then shouldShow = true end
        end
        
        if not Config.ESP or not shouldShow then
            box.Visible = false
            name.Visible = false
            dist.Visible = false
            continue
        end
        
        local char = pl.Character
        if not char then
            box.Visible = false
            name.Visible = false
            dist.Visible = false
            continue
        end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not hrp or not head then
            box.Visible = false
            name.Visible = false
            dist.Visible = false
            continue
        end
        
        local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then
            box.Visible = false
            name.Visible = false
            dist.Visible = false
            continue
        end
        
        local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        local boxHeight = math.abs(headPos.Y - legPos.Y)
        local boxWidth = boxHeight * 0.6
        
        -- Цвета
        if isWhitelisted then
            box.Color = Color3.fromRGB(255, 255, 255)
            name.Color = Color3.fromRGB(255, 255, 255)
            dist.Color = Color3.fromRGB(255, 255, 255)
        elseif isTargeted then
            box.Color = Color3.fromRGB(100, 150, 255)
            name.Color = Color3.fromRGB(100, 150, 255)
            dist.Color = Color3.fromRGB(100, 150, 255)
        else
            box.Color = Color3.fromRGB(255, 100, 100)
            name.Color = Color3.fromRGB(255, 100, 100)
            dist.Color = Color3.fromRGB(255, 100, 100)
        end
        
        box.Size = Vector2.new(boxWidth, boxHeight)
        box.Position = Vector2.new(pos.X - boxWidth/2, pos.Y - boxHeight/2)
        box.Visible = true
        
        name.Position = Vector2.new(pos.X, pos.Y - boxHeight/2 - 15)
        name.Text = pl.Name
        name.Visible = Config.ESPNames
        
        -- Дистанция
        local distance = math.floor((hrp.Position - character.HumanoidRootPart.Position).Magnitude)
        dist.Position = Vector2.new(pos.X, pos.Y + boxHeight/2 + 5)
        dist.Text = tostring(distance) .. "m"
        dist.Visible = Config.ESPDistance
    end
end

